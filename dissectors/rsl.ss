           (act-timing-adv (unwrap (read-u8 buffer 4)))
           (ms-power-lev (unwrap (read-u8 buffer 4)))
           (ms-fpc (unwrap (read-u8 buffer 4)))
           (paging-load (unwrap (read-u16be buffer 4)))
