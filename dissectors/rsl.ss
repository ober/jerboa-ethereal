        (cons 'a1-1 (list (cons 'raw a1-1) (cons 'formatted (if (= a1-1 0) "related to asynchronous handover procedure" "related to synchronous handover procedure"))))
        (cons 'a1-2 (list (cons 'raw a1-2) (cons 'formatted (if (= a1-2 0) "related to additional assignment procedure" "related to multislot configuration"))))
        (cons 'epc-mode (list (cons 'raw epc-mode) (cons 'formatted (if (= epc-mode 0) "Channel not in EPC mode" "Channel in EPC mode"))))
        (cons 'bs-fpc-epc-mode (list (cons 'raw bs-fpc-epc-mode) (cons 'formatted (if (= bs-fpc-epc-mode 0) "Fast Power Control not in use" "Fast Power Control in use"))))
        (cons 'T-bit (list (cons 'raw T-bit) (cons 'formatted (if (= T-bit 0) "Not considered transparent by BTS" "Considered transparent by BTS"))))
