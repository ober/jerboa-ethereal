           (key (unwrap (slice buffer 4 1)))
           (req-ref-T1prim (unwrap (read-u8 buffer 4)))
           (req-ref-T3 (unwrap (read-u16be buffer 4)))
           (req-ref-T2 (unwrap (read-u8 buffer 4)))
           (req-ref-rfn (unwrap (read-u16be buffer 4)))
           (ho-ref (unwrap (read-u8 buffer 4)))
           (l1inf-power-lev (unwrap (read-u8 buffer 4)))
           (l1inf-fpc (unwrap (read-u8 buffer 4)))
