           (phy-ctx-ab-err-bits (unwrap (read-u8 buffer 4)))
           (phy-ctx-ext-rand-access (unwrap (slice buffer 4 1)))
           (phy-ctx (unwrap (slice buffer 4 1)))
           (acc-delay (unwrap (read-u8 buffer 4)))
           (rach-slot-cnt (unwrap (read-u16be buffer 4)))
           (rach-busy-cnt (unwrap (read-u16be buffer 4)))
           (rach-acc-cnt (unwrap (read-u16be buffer 4)))
           (req-ref-ra (unwrap (read-u8 buffer 4)))
           (interf-band (unwrap (read-u8 buffer 4)))
           (interf-band-reserved (unwrap (read-u8 buffer 4)))
           (timing-adv (unwrap (read-u8 buffer 4)))
           (dtxd (unwrap (read-u8 buffer 4)))
           (meas-res-no (unwrap (read-u8 buffer 4)))
           (timing-offset (unwrap (read-u8 buffer 4)))
           (etws-pn (unwrap (slice buffer 4 1)))
           (cbch-load-type (unwrap (read-u8 buffer 4)))
           (msg-slt-cnt (unwrap (read-u8 buffer 4)))
           (command-ext (unwrap (read-u16be buffer 4)))
           (command (unwrap (read-u8 buffer 6)))
           (ch-no-TN (unwrap (read-u8 buffer 6)))
           (ie-length (unwrap (read-u16be buffer 6)))
           (rtd (unwrap (read-u8 buffer 6)))
           (tfo (unwrap (read-u8 buffer 6)))
           (paging-type (unwrap (read-u8 buffer 6)))
           (paging-group-cs (unwrap (read-u8 buffer 6)))
           (paging-group-empty-package (unwrap (read-u8 buffer 6)))
           (paging-group-ps-spare (unwrap (read-u8 buffer 6)))
           (paging-grp (unwrap (read-u8 buffer 6)))
           (paging-package-ch-no (unwrap (read-u8 buffer 6)))
           (osmo-rep-acch-ul-sacch (unwrap (read-u8 buffer 7)))
           (osmo-rep-acch-dl-sacch (unwrap (read-u8 buffer 7)))
           (osmo-rep-acch-dl-facch-all (unwrap (read-u8 buffer 7)))
           (osmo-rep-acch-dl-facch-cmd (unwrap (read-u8 buffer 7)))
           (osmo-top-acch-sacch (unwrap (read-u8 buffer 7)))
           (osmo-top-acch-facch (unwrap (read-u8 buffer 7)))
           (remote-ip (unwrap (read-u32be buffer 7)))
           (remote-port (unwrap (read-u16be buffer 7)))
           (local-ip (unwrap (read-u32be buffer 7)))
           (local-port (unwrap (read-u16be buffer 7)))
           (rtp-payload (unwrap (read-u8 buffer 7)))
           (conn-id (unwrap (read-u16be buffer 7)))
           (cstat-tx-pkts (unwrap (read-u32be buffer 7)))
           (cstat-tx-octs (unwrap (read-u32be buffer 7)))
           (cstat-rx-pkts (unwrap (read-u32be buffer 7)))
           (cstat-rx-octs (unwrap (read-u32be buffer 7)))
           (cstat-lost-pkts (unwrap (read-u32be buffer 7)))
           (cstat-ia-jitter (unwrap (read-u32be buffer 7)))
