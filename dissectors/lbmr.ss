        (cons 'queue-ver (list (cons 'raw queue-ver) (cons 'formatted (fmt-hex queue-ver))))
        (cons 'ip (list (cons 'raw ip) (cons 'formatted (fmt-ipv4 ip))))
        (cons 'port (list (cons 'raw port) (cons 'formatted (number->string port))))
        (cons 'inst-idx (list (cons 'raw inst-idx) (cons 'formatted (number->string inst-idx))))
        (cons 'grp-idx (list (cons 'raw grp-idx) (cons 'formatted (number->string grp-idx))))
        (cons 'il-num-insts (list (cons 'raw il-num-insts) (cons 'formatted (number->string il-num-insts))))
        (cons 'jrej-code (list (cons 'raw jrej-code) (cons 'formatted (number->string jrej-code))))
        (cons 'ev-bias (list (cons 'raw ev-bias) (cons 'formatted (number->string ev-bias))))
        (cons 'pckt-type-dep16 (list (cons 'raw pckt-type-dep16) (cons 'formatted (fmt-hex pckt-type-dep16))))
        (cons 'ctxinfo-len (list (cons 'raw ctxinfo-len) (cons 'formatted (number->string ctxinfo-len))))
        (cons 'ctxinfo-hop-count (list (cons 'raw ctxinfo-hop-count) (cons 'formatted (number->string ctxinfo-hop-count))))
        (cons 'ctxinfo-flags (list (cons 'raw ctxinfo-flags) (cons 'formatted (fmt-hex ctxinfo-flags))))
        (cons 'ctxinfo-port (list (cons 'raw ctxinfo-port) (cons 'formatted (number->string ctxinfo-port))))
        (cons 'ctxinfo-ip (list (cons 'raw ctxinfo-ip) (cons 'formatted (fmt-ipv4 ctxinfo-ip))))
        (cons 'ctxinfo-instance (list (cons 'raw ctxinfo-instance) (cons 'formatted (fmt-bytes ctxinfo-instance))))
        (cons 'ctxinfo-name (list (cons 'raw ctxinfo-name) (cons 'formatted (utf8->string ctxinfo-name))))
        (cons 'topic-res-request-flags (list (cons 'raw topic-res-request-flags) (cons 'formatted (fmt-hex topic-res-request-flags))))
        (cons 'remote-domain-route-hdr-num-domains (list (cons 'raw remote-domain-route-hdr-num-domains) (cons 'formatted (number->string remote-domain-route-hdr-num-domains))))
        (cons 'remote-domain-route-hdr-ip (list (cons 'raw remote-domain-route-hdr-ip) (cons 'formatted (fmt-ipv4 remote-domain-route-hdr-ip))))
        (cons 'remote-domain-route-hdr-port (list (cons 'raw remote-domain-route-hdr-port) (cons 'formatted (number->string remote-domain-route-hdr-port))))
        (cons 'remote-domain-route-hdr-route-index (list (cons 'raw remote-domain-route-hdr-route-index) (cons 'formatted (number->string remote-domain-route-hdr-route-index))))
        (cons 'remote-domain-route-hdr-length (list (cons 'raw remote-domain-route-hdr-length) (cons 'formatted (number->string remote-domain-route-hdr-length))))
        (cons 'rctxinfo-rec-address-len (list (cons 'raw rctxinfo-rec-address-len) (cons 'formatted (number->string rctxinfo-rec-address-len))))
        (cons 'rctxinfo-rec-address-flags (list (cons 'raw rctxinfo-rec-address-flags) (cons 'formatted (fmt-hex rctxinfo-rec-address-flags))))
        (cons 'rctxinfo-rec-address-domain-id (list (cons 'raw rctxinfo-rec-address-domain-id) (cons 'formatted (number->string rctxinfo-rec-address-domain-id))))
        (cons 'rctxinfo-rec-address-ip (list (cons 'raw rctxinfo-rec-address-ip) (cons 'formatted (fmt-ipv4 rctxinfo-rec-address-ip))))
        (cons 'rctxinfo-rec-address-port (list (cons 'raw rctxinfo-rec-address-port) (cons 'formatted (number->string rctxinfo-rec-address-port))))
        (cons 'rctxinfo-rec-address-res (list (cons 'raw rctxinfo-rec-address-res) (cons 'formatted (fmt-hex rctxinfo-rec-address-res))))
        (cons 'rctxinfo-rec-instance-len (list (cons 'raw rctxinfo-rec-instance-len) (cons 'formatted (number->string rctxinfo-rec-instance-len))))
        (cons 'rctxinfo-rec-instance-flags (list (cons 'raw rctxinfo-rec-instance-flags) (cons 'formatted (fmt-hex rctxinfo-rec-instance-flags))))
        (cons 'rctxinfo-rec-odomain-len (list (cons 'raw rctxinfo-rec-odomain-len) (cons 'formatted (number->string rctxinfo-rec-odomain-len))))
        (cons 'rctxinfo-rec-odomain-flags (list (cons 'raw rctxinfo-rec-odomain-flags) (cons 'formatted (fmt-hex rctxinfo-rec-odomain-flags))))
        (cons 'rctxinfo-rec-odomain-domain-id (list (cons 'raw rctxinfo-rec-odomain-domain-id) (cons 'formatted (number->string rctxinfo-rec-odomain-domain-id))))
        (cons 'rctxinfo-rec-name-len (list (cons 'raw rctxinfo-rec-name-len) (cons 'formatted (number->string rctxinfo-rec-name-len))))
        (cons 'rctxinfo-rec-name-flags (list (cons 'raw rctxinfo-rec-name-flags) (cons 'formatted (fmt-hex rctxinfo-rec-name-flags))))
        (cons 'rctxinfo-rec-name-name (list (cons 'raw rctxinfo-rec-name-name) (cons 'formatted (utf8->string rctxinfo-rec-name-name))))
        (cons 'rctxinfo-rec-unknown-len (list (cons 'raw rctxinfo-rec-unknown-len) (cons 'formatted (number->string rctxinfo-rec-unknown-len))))
        (cons 'rctxinfo-rec-unknown-flags (list (cons 'raw rctxinfo-rec-unknown-flags) (cons 'formatted (fmt-hex rctxinfo-rec-unknown-flags))))
        (cons 'rctxinfo-rec-unknown-data (list (cons 'raw rctxinfo-rec-unknown-data) (cons 'formatted (fmt-bytes rctxinfo-rec-unknown-data))))
        (cons 'rctxinfo-rec-len (list (cons 'raw rctxinfo-rec-len) (cons 'formatted (number->string rctxinfo-rec-len))))
        (cons 'rctxinfo-rec-flags (list (cons 'raw rctxinfo-rec-flags) (cons 'formatted (fmt-hex rctxinfo-rec-flags))))
        (cons 'rctxinfo-len (list (cons 'raw rctxinfo-len) (cons 'formatted (number->string rctxinfo-len))))
        (cons 'rctxinfo-num-recs (list (cons 'raw rctxinfo-num-recs) (cons 'formatted (number->string rctxinfo-num-recs))))
        (cons 'rctxinfo-reserved (list (cons 'raw rctxinfo-reserved) (cons 'formatted (fmt-hex rctxinfo-reserved))))
        (cons 'hdr-ver (list (cons 'raw hdr-ver) (cons 'formatted (number->string hdr-ver))))
        (cons 'hdr-opt (list (cons 'raw hdr-opt) (cons 'formatted (if (= hdr-opt 0) "False" "True"))))
        (cons 'opt-len-len (list (cons 'raw opt-len-len) (cons 'formatted (number->string opt-len-len))))
        (cons 'opt-len-total-len (list (cons 'raw opt-len-total-len) (cons 'formatted (number->string opt-len-total-len))))
        (cons 'opt-src-id-len (list (cons 'raw opt-src-id-len) (cons 'formatted (number->string opt-src-id-len))))
        (cons 'opt-src-id-flags (list (cons 'raw opt-src-id-flags) (cons 'formatted (fmt-hex opt-src-id-flags))))
        (cons 'opt-src-id-src-id (list (cons 'raw opt-src-id-src-id) (cons 'formatted (fmt-bytes opt-src-id-src-id))))
        (cons 'opt-src-type-len (list (cons 'raw opt-src-type-len) (cons 'formatted (number->string opt-src-type-len))))
        (cons 'opt-src-type-flags (list (cons 'raw opt-src-type-flags) (cons 'formatted (fmt-hex opt-src-type-flags))))
        (cons 'opt-version-len (list (cons 'raw opt-version-len) (cons 'formatted (number->string opt-version-len))))
        (cons 'opt-version-flags (list (cons 'raw opt-version-flags) (cons 'formatted (fmt-hex opt-version-flags))))
        (cons 'opt-version-version (list (cons 'raw opt-version-version) (cons 'formatted (number->string opt-version-version))))
        (cons 'opt-local-domain-len (list (cons 'raw opt-local-domain-len) (cons 'formatted (number->string opt-local-domain-len))))
        (cons 'opt-local-domain-flags (list (cons 'raw opt-local-domain-flags) (cons 'formatted (fmt-hex opt-local-domain-flags))))
        (cons 'opt-local-domain-local-domain-id (list (cons 'raw opt-local-domain-local-domain-id) (cons 'formatted (number->string opt-local-domain-local-domain-id))))
        (cons 'opt-unknown-len (list (cons 'raw opt-unknown-len) (cons 'formatted (number->string opt-unknown-len))))
        )))

    (catch (e)
      (err (str "LBMR parse error: " e)))))

;; dissect-lbmr: parse LBMR from bytevector
;; Returns (ok fields-alist) or (err message)