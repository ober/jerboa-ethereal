        (cons 'msg-rc (list (cons 'raw msg-rc) (cons 'formatted (number->string msg-rc))))
        (cons 'error-message (list (cons 'raw error-message) (cons 'formatted (utf8->string error-message))))
        (cons 'item-sid (list (cons 'raw item-sid) (cons 'formatted (fmt-hex item-sid))))
        (cons 'item-length-short (list (cons 'raw item-length-short) (cons 'formatted (number->string item-length-short))))
        (cons 'item-length-long (list (cons 'raw item-length-long) (cons 'formatted (number->string item-length-long))))
        (cons 'uncomplength (list (cons 'raw uncomplength) (cons 'formatted (number->string uncomplength))))
        (cons 'magic (list (cons 'raw magic) (cons 'formatted (fmt-hex magic))))
        (cons 'special (list (cons 'raw special) (cons 'formatted (fmt-hex special))))
        )))

    (catch (e)
      (err (str "SAPDIAG parse error: " e)))))

;; dissect-sapdiag: parse SAPDIAG from bytevector
;; Returns (ok fields-alist) or (err message)