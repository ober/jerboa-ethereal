           (scid (unwrap (slice buffer 59 1)))
           )

      (ok (list
        (cons 'fixed-bit (list (cons 'raw fixed-bit) (cons 'formatted (number->string fixed-bit))))
        (cons 'packet-length (list (cons 'raw packet-length) (cons 'formatted (number->string packet-length))))
        (cons 'connection-number (list (cons 'raw connection-number) (cons 'formatted (number->string connection-number))))
        (cons 'reassembled-in (list (cons 'raw reassembled-in) (cons 'formatted (number->string reassembled-in))))
        (cons 'padding-length (list (cons 'raw padding-length) (cons 'formatted (number->string padding-length))))
        (cons 'mp-path-ack-path-identifier (list (cons 'raw mp-path-ack-path-identifier) (cons 'formatted (number->string mp-path-ack-path-identifier))))
        (cons 'ack-largest-acknowledged (list (cons 'raw ack-largest-acknowledged) (cons 'formatted (number->string ack-largest-acknowledged))))
        (cons 'ack-ack-delay (list (cons 'raw ack-ack-delay) (cons 'formatted (number->string ack-ack-delay))))
