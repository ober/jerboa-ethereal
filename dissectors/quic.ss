           (stream-stream-id (unwrap (read-u64be buffer 1)))
           (stream-offset (unwrap (read-u64be buffer 1)))
           (stream-length (unwrap (read-u64be buffer 1)))
           (md-maximum-data (unwrap (read-u64be buffer 1)))
           (msd-stream-id (unwrap (read-u64be buffer 1)))
           (msd-maximum-stream-data (unwrap (read-u64be buffer 1)))
           (ms-max-streams (unwrap (read-u64be buffer 1)))
