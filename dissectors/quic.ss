           (oa-ipv6 (unwrap (slice buffer 37 16)))
           (oa-port (unwrap (read-u16be buffer 53)))
           (mp-ps-path-identifier (unwrap (read-u64be buffer 55)))
           (mp-ps-path-status-sequence-number (unwrap (read-u64be buffer 55)))
           (mp-maximum-paths (unwrap (read-u64be buffer 55)))
