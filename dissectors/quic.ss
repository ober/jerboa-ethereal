           (odcil (unwrap (read-u8 buffer 1)))
           (odcid (unwrap (slice buffer 1 1)))
           (retry-token (unwrap (slice buffer 1 1)))
           (retry-integrity-tag (unwrap (slice buffer 1 16)))
           (token-length (unwrap (read-u64be buffer 1)))
           (length (unwrap (read-u64be buffer 1)))
           (packet-number (unwrap (read-u64be buffer 1)))
           (payload (unwrap (slice buffer 1 1)))
           (dcid (unwrap (slice buffer 1 1)))
           (protected-payload (unwrap (slice buffer 1 1)))
           (mp-rc-path-identifier (unwrap (read-u64be buffer 17)))
           (rci-sequence (unwrap (read-u64be buffer 17)))
           (path-challenge-data (unwrap (slice buffer 17 8)))
           (path-response-data (unwrap (slice buffer 25 8)))
           (mp-pa-path-identifier (unwrap (read-u64be buffer 33)))
           (mp-pa-error-code (unwrap (read-u64be buffer 33)))
           (cc-frame-type (unwrap (read-u64be buffer 33)))
           (cc-error-code-app (unwrap (read-u64be buffer 33)))
           (cc-reason-phrase-length (unwrap (read-u64be buffer 33)))
           (dg-length (unwrap (read-u64be buffer 33)))
           (af-sequence-number (unwrap (read-u64be buffer 33)))
           (af-ack-eliciting-threshold (unwrap (read-u64be buffer 33)))
           (af-request-max-ack-delay (unwrap (read-u64be buffer 33)))
