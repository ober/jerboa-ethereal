        (cons 'evt-input-unused (list (cons 'raw evt-input-unused) (cons 'formatted (fmt-hex evt-input-unused))))
        (cons 'evt-linear-pcm-bit-pos (list (cons 'raw evt-linear-pcm-bit-pos) (cons 'formatted (number->string evt-linear-pcm-bit-pos))))
        (cons 'evt-num-broadcast-retransm (list (cons 'raw evt-num-broadcast-retransm) (cons 'formatted (number->string evt-num-broadcast-retransm))))
        (cons 'evt-hold-mode-act-page (list (cons 'raw evt-hold-mode-act-page) (cons 'formatted (number->string evt-hold-mode-act-page))))
        (cons 'evt-hold-mode-act-inquiry (list (cons 'raw evt-hold-mode-act-inquiry) (cons 'formatted (number->string evt-hold-mode-act-inquiry))))
        (cons 'evt-hold-mode-act-periodic (list (cons 'raw evt-hold-mode-act-periodic) (cons 'formatted (number->string evt-hold-mode-act-periodic))))
        (cons 'evt-num-supp-iac (list (cons 'raw evt-num-supp-iac) (cons 'formatted (number->string evt-num-supp-iac))))
        (cons 'evt-num-curr-iac (list (cons 'raw evt-num-curr-iac) (cons 'formatted (number->string evt-num-curr-iac))))
        (cons 'evt-fec-required (list (cons 'raw evt-fec-required) (cons 'formatted (number->string evt-fec-required))))
        (cons 'evt-hash-c (list (cons 'raw evt-hash-c) (cons 'formatted (fmt-bytes evt-hash-c))))
        (cons 'evt-randomizer-r (list (cons 'raw evt-randomizer-r) (cons 'formatted (fmt-bytes evt-randomizer-r))))
        (cons 'evt-location-domain-aware (list (cons 'raw evt-location-domain-aware) (cons 'formatted (number->string evt-location-domain-aware))))
        (cons 'evt-location-domain (list (cons 'raw evt-location-domain) (cons 'formatted (utf8->string evt-location-domain))))
        (cons 'evt-location-domain-options (list (cons 'raw evt-location-domain-options) (cons 'formatted (utf8->string evt-location-domain-options))))
        (cons 'evt-location-options (list (cons 'raw evt-location-options) (cons 'formatted (fmt-hex evt-location-options))))
        (cons 'evt-transmit-power-level-gfsk (list (cons 'raw evt-transmit-power-level-gfsk) (cons 'formatted (number->string evt-transmit-power-level-gfsk))))
        (cons 'evt-transmit-power-level-dqpsk (list (cons 'raw evt-transmit-power-level-dqpsk) (cons 'formatted (number->string evt-transmit-power-level-dqpsk))))
        (cons 'evt-transmit-power-level-8dpsk (list (cons 'raw evt-transmit-power-level-8dpsk) (cons 'formatted (number->string evt-transmit-power-level-8dpsk))))
        (cons 'evt-flush-to-us (list (cons 'raw evt-flush-to-us) (cons 'formatted (number->string evt-flush-to-us))))
        (cons 'evt-le-supported-host (list (cons 'raw evt-le-supported-host) (cons 'formatted (number->string evt-le-supported-host))))
        (cons 'evt-le-simultaneous-host (list (cons 'raw evt-le-simultaneous-host) (cons 'formatted (number->string evt-le-simultaneous-host))))
        (cons 'evt-hci-revision (list (cons 'raw evt-hci-revision) (cons 'formatted (number->string evt-hci-revision))))
        (cons 'evt-sub-vers-nr (list (cons 'raw evt-sub-vers-nr) (cons 'formatted (number->string evt-sub-vers-nr))))
        (cons 'evt-local-supported-cmds (list (cons 'raw evt-local-supported-cmds) (cons 'formatted (fmt-bytes evt-local-supported-cmds))))
        (cons 'evt-host-data-packet-length-acl (list (cons 'raw evt-host-data-packet-length-acl) (cons 'formatted (number->string evt-host-data-packet-length-acl))))
        (cons 'evt-host-data-packet-length-sco (list (cons 'raw evt-host-data-packet-length-sco) (cons 'formatted (number->string evt-host-data-packet-length-sco))))
        (cons 'evt-host-total-num-acl-data-packets (list (cons 'raw evt-host-total-num-acl-data-packets) (cons 'formatted (number->string evt-host-total-num-acl-data-packets))))
        (cons 'evt-host-total-num-sco-data-packets (list (cons 'raw evt-host-total-num-sco-data-packets) (cons 'formatted (number->string evt-host-total-num-sco-data-packets))))
        (cons 'evt-max-acl-data-packet-length (list (cons 'raw evt-max-acl-data-packet-length) (cons 'formatted (fmt-hex evt-max-acl-data-packet-length))))
        (cons 'evt-data-block-length (list (cons 'raw evt-data-block-length) (cons 'formatted (fmt-hex evt-data-block-length))))
        (cons 'evt-total-num-data-blocks (list (cons 'raw evt-total-num-data-blocks) (cons 'formatted (fmt-hex evt-total-num-data-blocks))))
        (cons 'evt-number-of-supported-codecs (list (cons 'raw evt-number-of-supported-codecs) (cons 'formatted (number->string evt-number-of-supported-codecs))))
        (cons 'evt-number-of-supported-vendor-codecs (list (cons 'raw evt-number-of-supported-vendor-codecs) (cons 'formatted (number->string evt-number-of-supported-vendor-codecs))))
        (cons 'evt-vendor-codecs-item (list (cons 'raw evt-vendor-codecs-item) (cons 'formatted (utf8->string evt-vendor-codecs-item))))
        (cons 'evt-vendor-codec-id (list (cons 'raw evt-vendor-codec-id) (cons 'formatted (fmt-hex evt-vendor-codec-id))))
        (cons 'evt-simple-pairing-options (list (cons 'raw evt-simple-pairing-options) (cons 'formatted (fmt-hex evt-simple-pairing-options))))
        (cons 'evt-simple-pairing-options-remote-public-key-validation (list (cons 'raw evt-simple-pairing-options-remote-public-key-validation) (cons 'formatted (if (= evt-simple-pairing-options-remote-public-key-validation 0) "Not set" "Set"))))
        (cons 'evt-simple-pairing-options-reserved (list (cons 'raw evt-simple-pairing-options-reserved) (cons 'formatted (if (= evt-simple-pairing-options-reserved 0) "Not set" "Set"))))
        (cons 'evt-failed-contact-counter (list (cons 'raw evt-failed-contact-counter) (cons 'formatted (number->string evt-failed-contact-counter))))
        (cons 'evt-link-quality (list (cons 'raw evt-link-quality) (cons 'formatted (number->string evt-link-quality))))
        (cons 'evt-clock-accuracy (list (cons 'raw evt-clock-accuracy) (cons 'formatted (fmt-hex evt-clock-accuracy))))
        (cons 'evt-total-bandwidth (list (cons 'raw evt-total-bandwidth) (cons 'formatted (number->string evt-total-bandwidth))))
        (cons 'evt-max-guaranteed-bandwidth (list (cons 'raw evt-max-guaranteed-bandwidth) (cons 'formatted (number->string evt-max-guaranteed-bandwidth))))
        (cons 'evt-min-latency (list (cons 'raw evt-min-latency) (cons 'formatted (number->string evt-min-latency))))
        (cons 'evt-max-pdu-size (list (cons 'raw evt-max-pdu-size) (cons 'formatted (number->string evt-max-pdu-size))))
        (cons 'evt-pal-capabilities-00 (list (cons 'raw evt-pal-capabilities-00) (cons 'formatted (number->string evt-pal-capabilities-00))))
        (cons 'evt-max-amp-assoc-length (list (cons 'raw evt-max-amp-assoc-length) (cons 'formatted (number->string evt-max-amp-assoc-length))))
        (cons 'evt-max-flush-to-us (list (cons 'raw evt-max-flush-to-us) (cons 'formatted (number->string evt-max-flush-to-us))))
        (cons 'evt-best-effort-flush-to-us (list (cons 'raw evt-best-effort-flush-to-us) (cons 'formatted (number->string evt-best-effort-flush-to-us))))
        (cons 'evt-amp-remaining-assoc-length (list (cons 'raw evt-amp-remaining-assoc-length) (cons 'formatted (number->string evt-amp-remaining-assoc-length))))
        (cons 'evt-amp-assoc-fragment (list (cons 'raw evt-amp-assoc-fragment) (cons 'formatted (fmt-bytes evt-amp-assoc-fragment))))
        (cons 'evt-physical-link-handle (list (cons 'raw evt-physical-link-handle) (cons 'formatted (fmt-hex evt-physical-link-handle))))
        (cons 'evt-mws-number-of-transports (list (cons 'raw evt-mws-number-of-transports) (cons 'formatted (number->string evt-mws-number-of-transports))))
        )))

    (catch (e)
      (err (str "BTHCI-EVT parse error: " e)))))

