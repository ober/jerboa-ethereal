        (cons 'niagara-networks-dnsadditionaltypetext (list (cons 'raw niagara-networks-dnsadditionaltypetext) (cons 'formatted (utf8->string niagara-networks-dnsadditionaltypetext))))
        (cons 'niagara-networks-dnsadditionalclass (list (cons 'raw niagara-networks-dnsadditionalclass) (cons 'formatted (number->string niagara-networks-dnsadditionalclass))))
        (cons 'niagara-networks-dnsadditionalclasstext (list (cons 'raw niagara-networks-dnsadditionalclasstext) (cons 'formatted (utf8->string niagara-networks-dnsadditionalclasstext))))
        (cons 'niagara-networks-dnsadditionalttl (list (cons 'raw niagara-networks-dnsadditionalttl) (cons 'formatted (number->string niagara-networks-dnsadditionalttl))))
        (cons 'niagara-networks-dnsadditionalrdlength (list (cons 'raw niagara-networks-dnsadditionalrdlength) (cons 'formatted (number->string niagara-networks-dnsadditionalrdlength))))
        (cons 'niagara-networks-dnsadditionalrdata (list (cons 'raw niagara-networks-dnsadditionalrdata) (cons 'formatted (utf8->string niagara-networks-dnsadditionalrdata))))
        (cons 'niagara-networks-radiuspackettypecode (list (cons 'raw niagara-networks-radiuspackettypecode) (cons 'formatted (number->string niagara-networks-radiuspackettypecode))))
        (cons 'niagara-networks-radiuspackettypecodetext (list (cons 'raw niagara-networks-radiuspackettypecodetext) (cons 'formatted (utf8->string niagara-networks-radiuspackettypecodetext))))
        (cons 'niagara-networks-radiuspacketidentifier (list (cons 'raw niagara-networks-radiuspacketidentifier) (cons 'formatted (fmt-hex niagara-networks-radiuspacketidentifier))))
        (cons 'niagara-networks-radiusauthenticator (list (cons 'raw niagara-networks-radiusauthenticator) (cons 'formatted (fmt-bytes niagara-networks-radiusauthenticator))))
        (cons 'niagara-networks-radiususername (list (cons 'raw niagara-networks-radiususername) (cons 'formatted (utf8->string niagara-networks-radiususername))))
        (cons 'niagara-networks-radiuscallingstationid (list (cons 'raw niagara-networks-radiuscallingstationid) (cons 'formatted (utf8->string niagara-networks-radiuscallingstationid))))
        (cons 'niagara-networks-radiuscalledstationid (list (cons 'raw niagara-networks-radiuscalledstationid) (cons 'formatted (utf8->string niagara-networks-radiuscalledstationid))))
        (cons 'niagara-networks-radiusnasipaddress (list (cons 'raw niagara-networks-radiusnasipaddress) (cons 'formatted (fmt-ipv4 niagara-networks-radiusnasipaddress))))
        (cons 'niagara-networks-radiusnasipv6address (list (cons 'raw niagara-networks-radiusnasipv6address) (cons 'formatted (fmt-ipv6-address niagara-networks-radiusnasipv6address))))
        (cons 'niagara-networks-radiusnasidentifier (list (cons 'raw niagara-networks-radiusnasidentifier) (cons 'formatted (utf8->string niagara-networks-radiusnasidentifier))))
        (cons 'niagara-networks-radiusframedipaddress (list (cons 'raw niagara-networks-radiusframedipaddress) (cons 'formatted (fmt-ipv4 niagara-networks-radiusframedipaddress))))
        (cons 'niagara-networks-radiusframedipv6address (list (cons 'raw niagara-networks-radiusframedipv6address) (cons 'formatted (fmt-ipv6-address niagara-networks-radiusframedipv6address))))
        (cons 'niagara-networks-radiusacctsessionid (list (cons 'raw niagara-networks-radiusacctsessionid) (cons 'formatted (utf8->string niagara-networks-radiusacctsessionid))))
        (cons 'niagara-networks-radiusacctstatustype (list (cons 'raw niagara-networks-radiusacctstatustype) (cons 'formatted (utf8->string niagara-networks-radiusacctstatustype))))
        (cons 'niagara-networks-radiusacctinoctets (list (cons 'raw niagara-networks-radiusacctinoctets) (cons 'formatted (number->string niagara-networks-radiusacctinoctets))))
        (cons 'niagara-networks-radiusacctoutoctets (list (cons 'raw niagara-networks-radiusacctoutoctets) (cons 'formatted (number->string niagara-networks-radiusacctoutoctets))))
        (cons 'niagara-networks-radiusacctinpackets (list (cons 'raw niagara-networks-radiusacctinpackets) (cons 'formatted (number->string niagara-networks-radiusacctinpackets))))
        (cons 'niagara-networks-radiusacctoutpackets (list (cons 'raw niagara-networks-radiusacctoutpackets) (cons 'formatted (number->string niagara-networks-radiusacctoutpackets))))
        (cons 'niagara-networks-radiusvsavendorid (list (cons 'raw niagara-networks-radiusvsavendorid) (cons 'formatted (number->string niagara-networks-radiusvsavendorid))))
        (cons 'niagara-networks-radiusvsaname (list (cons 'raw niagara-networks-radiusvsaname) (cons 'formatted (utf8->string niagara-networks-radiusvsaname))))
        (cons 'niagara-networks-radiusvsaid (list (cons 'raw niagara-networks-radiusvsaid) (cons 'formatted (number->string niagara-networks-radiusvsaid))))
        (cons 'niagara-networks-radiusvsavalue (list (cons 'raw niagara-networks-radiusvsavalue) (cons 'formatted (fmt-bytes niagara-networks-radiusvsavalue))))
        (cons 'juniper-cpdesc-16bit (list (cons 'raw juniper-cpdesc-16bit) (cons 'formatted (number->string juniper-cpdesc-16bit))))
        (cons 'juniper-cpdesc-32bit (list (cons 'raw juniper-cpdesc-32bit) (cons 'formatted (number->string juniper-cpdesc-32bit))))
        (cons 'unknown-field-type (list (cons 'raw unknown-field-type) (cons 'formatted (fmt-bytes unknown-field-type))))
        (cons 'enterprise-private-entry (list (cons 'raw enterprise-private-entry) (cons 'formatted (fmt-bytes enterprise-private-entry))))
        (cons 'template-ipfix-pen-provided (list (cons 'raw template-ipfix-pen-provided) (cons 'formatted (if (= template-ipfix-pen-provided 0) "False" "True"))))
        (cons 'template-ipfix-field-type-enterprise (list (cons 'raw template-ipfix-field-type-enterprise) (cons 'formatted (number->string template-ipfix-field-type-enterprise))))
        (cons 'template-field-length (list (cons 'raw template-field-length) (cons 'formatted (number->string template-field-length))))
        (cons 'template-ipfix-field-pen (list (cons 'raw template-ipfix-field-pen) (cons 'formatted (number->string template-ipfix-field-pen))))
        (cons 'option-scope-length (list (cons 'raw option-scope-length) (cons 'formatted (number->string option-scope-length))))
        (cons 'option-length (list (cons 'raw option-length) (cons 'formatted (number->string option-length))))
        (cons 'template-ipfix-total-field-count (list (cons 'raw template-ipfix-total-field-count) (cons 'formatted (number->string template-ipfix-total-field-count))))
        (cons 'template-ipfix-scope-field-count (list (cons 'raw template-ipfix-scope-field-count) (cons 'formatted (number->string template-ipfix-scope-field-count))))
        (cons 'template-id (list (cons 'raw template-id) (cons 'formatted (number->string template-id))))
        (cons 'template-field-count (list (cons 'raw template-field-count) (cons 'formatted (number->string template-field-count))))
        (cons 'srcaddr (list (cons 'raw srcaddr) (cons 'formatted (fmt-ipv4 srcaddr))))
        (cons 'dstaddr (list (cons 'raw dstaddr) (cons 'formatted (fmt-ipv4 dstaddr))))
        (cons 'nexthop (list (cons 'raw nexthop) (cons 'formatted (fmt-ipv4 nexthop))))
        (cons 'routersc (list (cons 'raw routersc) (cons 'formatted (fmt-ipv4 routersc))))
        )))

    (catch (e)
      (err (str "NETFLOW parse error: " e)))))

;; dissect-netflow: parse NETFLOW from bytevector
;; Returns (ok fields-alist) or (err message)