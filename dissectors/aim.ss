        (cons 'dcinfo-auth-cookie (list (cons 'raw dcinfo-auth-cookie) (cons 'formatted (fmt-bytes dcinfo-auth-cookie))))
        (cons 'fnac-subtype (list (cons 'raw fnac-subtype) (cons 'formatted (fmt-hex fnac-subtype))))
        (cons 'messageblock-message (list (cons 'raw messageblock-message) (cons 'formatted (utf8->string messageblock-message))))
        (cons 'tlv-value-id (list (cons 'raw tlv-value-id) (cons 'formatted (number->string tlv-value-id))))
        (cons 'icbm-min-msg-interval (list (cons 'raw icbm-min-msg-interval) (cons 'formatted (number->string icbm-min-msg-interval))))
        (cons 'messaging-plugin (list (cons 'raw messaging-plugin) (cons 'formatted (fmt-bytes messaging-plugin))))
        (cons 'icbm-rendezvous-nak-length (list (cons 'raw icbm-rendezvous-nak-length) (cons 'formatted (fmt-hex icbm-rendezvous-nak-length))))
        (cons 'dcinfo-webport (list (cons 'raw dcinfo-webport) (cons 'formatted (number->string dcinfo-webport))))
        (cons 'icbm-client-err-length (list (cons 'raw icbm-client-err-length) (cons 'formatted (number->string icbm-client-err-length))))
        (cons 'fnac-flags (list (cons 'raw fnac-flags) (cons 'formatted (fmt-hex fnac-flags))))
        (cons 'fnac-flag-next-is-related (list (cons 'raw fnac-flag-next-is-related) (cons 'formatted (if (= fnac-flag-next-is-related 0) "Not set" "Set"))))
        (cons 'fnac-flag-contains-version (list (cons 'raw fnac-flag-contains-version) (cons 'formatted (if (= fnac-flag-contains-version 0) "Not set" "Set"))))
        (cons 'tlv-length (list (cons 'raw tlv-length) (cons 'formatted (number->string tlv-length))))
        (cons 'rateinfo-limitlevel (list (cons 'raw rateinfo-limitlevel) (cons 'formatted (fmt-hex rateinfo-limitlevel))))
        (cons 'icbm-client-err-downcounter (list (cons 'raw icbm-client-err-downcounter) (cons 'formatted (number->string icbm-client-err-downcounter))))
        (cons 'fnac-id (list (cons 'raw fnac-id) (cons 'formatted (fmt-hex fnac-id))))
        (cons 'tlvcount (list (cons 'raw tlvcount) (cons 'formatted (number->string tlvcount))))
        (cons 'dcinfo-client-future (list (cons 'raw dcinfo-client-future) (cons 'formatted (fmt-hex dcinfo-client-future))))
        (cons 'messaging-unknown-data (list (cons 'raw messaging-unknown-data) (cons 'formatted (fmt-bytes messaging-unknown-data))))
        (cons 'messaging-plugin-specific-data (list (cons 'raw messaging-plugin-specific-data) (cons 'formatted (fmt-bytes messaging-plugin-specific-data))))
        (cons 'version (list (cons 'raw version) (cons 'formatted (fmt-bytes version))))
        (cons 'rateinfo-disconnectlevel (list (cons 'raw rateinfo-disconnectlevel) (cons 'formatted (fmt-hex rateinfo-disconnectlevel))))
        (cons 'dcinfo-last-info-update (list (cons 'raw dcinfo-last-info-update) (cons 'formatted (number->string dcinfo-last-info-update))))
        (cons 'data (list (cons 'raw data) (cons 'formatted (fmt-bytes data))))
        (cons 'buddyname-len (list (cons 'raw buddyname-len) (cons 'formatted (number->string buddyname-len))))
        (cons 'buddyname (list (cons 'raw buddyname) (cons 'formatted (utf8->string buddyname))))
        (cons 'nickinfo-caps (list (cons 'raw nickinfo-caps) (cons 'formatted (fmt-bytes nickinfo-caps))))
        (cons 'nickinfo-short-caps (list (cons 'raw nickinfo-short-caps) (cons 'formatted (fmt-hex nickinfo-short-caps))))
        (cons 'rateinfo-currentlevel (list (cons 'raw rateinfo-currentlevel) (cons 'formatted (fmt-hex rateinfo-currentlevel))))
        (cons 'dcinfo-last-ext-info-update (list (cons 'raw dcinfo-last-ext-info-update) (cons 'formatted (number->string dcinfo-last-ext-info-update))))
        (cons 'rateinfo-maxlevel (list (cons 'raw rateinfo-maxlevel) (cons 'formatted (fmt-hex rateinfo-maxlevel))))
        (cons 'dcinfo-last-ext-status-update (list (cons 'raw dcinfo-last-ext-status-update) (cons 'formatted (number->string dcinfo-last-ext-status-update))))
        (cons 'rateinfo-lasttime (list (cons 'raw rateinfo-lasttime) (cons 'formatted (fmt-hex rateinfo-lasttime))))
        (cons 'chat-screen-name (list (cons 'raw chat-screen-name) (cons 'formatted (utf8->string chat-screen-name))))
        (cons 'dcinfo-unknown (list (cons 'raw dcinfo-unknown) (cons 'formatted (number->string dcinfo-unknown))))
        )))

    (catch (e)
      (err (str "AIM parse error: " e)))))

;; dissect-aim: parse AIM from bytevector
;; Returns (ok fields-alist) or (err message)