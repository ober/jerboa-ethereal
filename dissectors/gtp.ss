        (cons 'cmn-flg-mbs-srv-type (list (cons 'raw cmn-flg-mbs-srv-type) (cons 'formatted (number->string cmn-flg-mbs-srv-type))))
        (cons 'cmn-flg-ppc (list (cons 'raw cmn-flg-ppc) (cons 'formatted (number->string cmn-flg-ppc))))
        (cons 'ext-apn-res (list (cons 'raw ext-apn-res) (cons 'formatted (number->string ext-apn-res))))
        (cons 'ext-ggsn-back-off-timer (list (cons 'raw ext-ggsn-back-off-timer) (cons 'formatted (number->string ext-ggsn-back-off-timer))))
        (cons 'cgi-ci (list (cons 'raw cgi-ci) (cons 'formatted (number->string cgi-ci))))
        (cons 'lapi (list (cons 'raw lapi) (cons 'formatted (if (= lapi 0) "MS is not configured for NAS signalling low priority" "MS is configured for NAS signalling low priority"))))
        (cons 'sai-sac (list (cons 'raw sai-sac) (cons 'formatted (number->string sai-sac))))
        (cons 'max-mbr-apn-ambr-ul (list (cons 'raw max-mbr-apn-ambr-ul) (cons 'formatted (number->string max-mbr-apn-ambr-ul))))
        (cons 'lac (list (cons 'raw lac) (cons 'formatted (number->string lac))))
        (cons 'max-mbr-apn-ambr-dl (list (cons 'raw max-mbr-apn-ambr-dl) (cons 'formatted (number->string max-mbr-apn-ambr-dl))))
        (cons 'rai-rac (list (cons 'raw rai-rac) (cons 'formatted (number->string rai-rac))))
        (cons 'timezone (list (cons 'raw timezone) (cons 'formatted (number->string timezone))))
        (cons 'linked-nsapi (list (cons 'raw linked-nsapi) (cons 'formatted (number->string linked-nsapi))))
        (cons 'uplink-teid-cp (list (cons 'raw uplink-teid-cp) (cons 'formatted (fmt-hex uplink-teid-cp))))
        (cons 'ms-cm-2-len (list (cons 'raw ms-cm-2-len) (cons 'formatted (number->string ms-cm-2-len))))
        (cons 'ms-cm-3-len (list (cons 'raw ms-cm-3-len) (cons 'formatted (number->string ms-cm-3-len))))
        (cons 'sup-codec-lst-len (list (cons 'raw sup-codec-lst-len) (cons 'formatted (number->string sup-codec-lst-len))))
        (cons 'add-flg-for-srvcc-ics (list (cons 'raw add-flg-for-srvcc-ics) (cons 'formatted (if (= add-flg-for-srvcc-ics 0) "False" "True"))))
        (cons 'pdp-address-length (list (cons 'raw pdp-address-length) (cons 'formatted (number->string pdp-address-length))))
        (cons 'pdp-address-ipv4 (list (cons 'raw pdp-address-ipv4) (cons 'formatted (fmt-ipv4 pdp-address-ipv4))))
        (cons 'pdp-address-ipv6 (list (cons 'raw pdp-address-ipv6) (cons 'formatted (fmt-ipv6-address pdp-address-ipv6))))
        (cons 'ggsn-address-length (list (cons 'raw ggsn-address-length) (cons 'formatted (number->string ggsn-address-length))))
        (cons 'ggsn-address-for-control-plane-ipv4 (list (cons 'raw ggsn-address-for-control-plane-ipv4) (cons 'formatted (fmt-ipv4 ggsn-address-for-control-plane-ipv4))))
        (cons 'ggsn-address-for-control-plane-ipv6 (list (cons 'raw ggsn-address-for-control-plane-ipv6) (cons 'formatted (fmt-ipv6-address ggsn-address-for-control-plane-ipv6))))
        (cons 'transaction-identifier (list (cons 'raw transaction-identifier) (cons 'formatted (number->string transaction-identifier))))
        (cons 'tmgi (list (cons 'raw tmgi) (cons 'formatted (fmt-bytes tmgi))))
        (cons 'rim-routing-addr (list (cons 'raw rim-routing-addr) (cons 'formatted (fmt-bytes rim-routing-addr))))
        (cons 'macro-enodeb-id (list (cons 'raw macro-enodeb-id) (cons 'formatted (fmt-hex macro-enodeb-id))))
        (cons 'home-enodeb-id (list (cons 'raw home-enodeb-id) (cons 'formatted (fmt-hex home-enodeb-id))))
        (cons 'ext-hdr-pdcpsn (list (cons 'raw ext-hdr-pdcpsn) (cons 'formatted (number->string ext-hdr-pdcpsn))))
        (cons 'tpdu-data (list (cons 'raw tpdu-data) (cons 'formatted (fmt-bytes tpdu-data))))
        (cons 'tac (list (cons 'raw tac) (cons 'formatted (number->string tac))))
        (cons 'lhn-id (list (cons 'raw lhn-id) (cons 'formatted (utf8->string lhn-id))))
        (cons 'ue-usage-type-value (list (cons 'raw ue-usage-type-value) (cons 'formatted (number->string ue-usage-type-value))))
        (cons 'ext-comm-flags-II-pnsi (list (cons 'raw ext-comm-flags-II-pnsi) (cons 'formatted (number->string ext-comm-flags-II-pnsi))))
        (cons 'ext-comm-flags-II-dtci (list (cons 'raw ext-comm-flags-II-dtci) (cons 'formatted (number->string ext-comm-flags-II-dtci))))
        (cons 'ext-comm-flags-II-pmtsmi (list (cons 'raw ext-comm-flags-II-pmtsmi) (cons 'formatted (number->string ext-comm-flags-II-pmtsmi))))
        (cons 'ext-comm-flags-II-spare (list (cons 'raw ext-comm-flags-II-spare) (cons 'formatted (fmt-hex ext-comm-flags-II-spare))))
        (cons 'ciot-opt-sup-ind-sgni-pdn (list (cons 'raw ciot-opt-sup-ind-sgni-pdn) (cons 'formatted (number->string ciot-opt-sup-ind-sgni-pdn))))
        (cons 'ciot-opt-sup-ind-scni-pdn (list (cons 'raw ciot-opt-sup-ind-scni-pdn) (cons 'formatted (number->string ciot-opt-sup-ind-scni-pdn))))
        (cons 'ciot-opt-sup-ind-spare (list (cons 'raw ciot-opt-sup-ind-spare) (cons 'formatted (fmt-hex ciot-opt-sup-ind-spare))))
        (cons 'apn-length (list (cons 'raw apn-length) (cons 'formatted (number->string apn-length))))
        (cons 'nsapi (list (cons 'raw nsapi) (cons 'formatted (number->string nsapi))))
        (cons 'scef-id-length (list (cons 'raw scef-id-length) (cons 'formatted (number->string scef-id-length))))
        (cons 'scef-id (list (cons 'raw scef-id) (cons 'formatted (utf8->string scef-id))))
        (cons 'iov-updates-counter (list (cons 'raw iov-updates-counter) (cons 'formatted (number->string iov-updates-counter))))
        (cons 'mapped-ue-usage-type (list (cons 'raw mapped-ue-usage-type) (cons 'formatted (number->string mapped-ue-usage-type))))
        (cons 'up-fun-sel-ind-flags-dcnr (list (cons 'raw up-fun-sel-ind-flags-dcnr) (cons 'formatted (number->string up-fun-sel-ind-flags-dcnr))))
        (cons 'up-fun-sel-ind-flags-spare (list (cons 'raw up-fun-sel-ind-flags-spare) (cons 'formatted (fmt-hex up-fun-sel-ind-flags-spare))))
        (cons 'length (list (cons 'raw length) (cons 'formatted (number->string length))))
        (cons 'number-of-data-records (list (cons 'raw number-of-data-records) (cons 'formatted (number->string number-of-data-records))))
        (cons 'data-record-format (list (cons 'raw data-record-format) (cons 'formatted (number->string data-record-format))))
        (cons 'cdr-app (list (cons 'raw cdr-app) (cons 'formatted (number->string cdr-app))))
        (cons 'cdr-rel (list (cons 'raw cdr-rel) (cons 'formatted (number->string cdr-rel))))
        (cons 'cdr-ver (list (cons 'raw cdr-ver) (cons 'formatted (number->string cdr-ver))))
        (cons 'cdr-rel-ext (list (cons 'raw cdr-rel-ext) (cons 'formatted (number->string cdr-rel-ext))))
        (cons 'cdr-length (list (cons 'raw cdr-length) (cons 'formatted (number->string cdr-length))))
        (cons 'cdr-context (list (cons 'raw cdr-context) (cons 'formatted (fmt-bytes cdr-context))))
        (cons 'node-address-length (list (cons 'raw node-address-length) (cons 'formatted (number->string node-address-length))))
        (cons 'node-ipv4 (list (cons 'raw node-ipv4) (cons 'formatted (fmt-ipv4 node-ipv4))))
        (cons 'node-ipv6 (list (cons 'raw node-ipv6) (cons 'formatted (fmt-ipv6-address node-ipv6))))
        (cons 'ext-length (list (cons 'raw ext-length) (cons 'formatted (number->string ext-length))))
        (cons 'ext-val (list (cons 'raw ext-val) (cons 'formatted (fmt-bytes ext-val))))
        )))

    (catch (e)
      (err (str "GTP parse error: " e)))))

;; dissect-gtp: parse GTP from bytevector
;; Returns (ok fields-alist) or (err message)