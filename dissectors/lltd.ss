           (device-uuid (unwrap (slice buffer 0 22)))
           (qos-char-e (unwrap (read-u8 buffer 0)))
           (qos-char-q (unwrap (read-u8 buffer 0)))
           (qos-char-p (unwrap (read-u8 buffer 0)))
           (qos-char-reserved (unwrap (read-u32be buffer 0)))
           (sees-list-working-set (unwrap (read-u16be buffer 0)))
           (discovery-real-dest-addr (unwrap (slice buffer 0 6)))
           (discovery-real-src-addr (unwrap (slice buffer 0 6)))
