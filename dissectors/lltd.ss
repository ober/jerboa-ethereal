           (discover-gen-num (unwrap (read-u16be buffer 0)))
           (discover-num-stations (unwrap (read-u16be buffer 0)))
           (reserved (unwrap (read-u8 buffer 2)))
           (hello-gen-num (unwrap (read-u16be buffer 6)))
           (hello-current-address (unwrap (slice buffer 6 6)))
           (hello-apparent-address (unwrap (slice buffer 6 6)))
           (emit-num-descs (unwrap (read-u16be buffer 6)))
           (queryresp-more-descs (unwrap (read-u8 buffer 20)))
           (queryresp-memory-descs (unwrap (read-u8 buffer 20)))
           (queryresp-num-descs (unwrap (read-u16be buffer 20)))
           (flat-crc-bytes (unwrap (read-u32be buffer 40)))
           (flat-crc-packets (unwrap (read-u8 buffer 40)))
