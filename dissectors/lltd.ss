           (querylargeresp-more-descs (unwrap (read-u8 buffer 40)))
           (querylargeresp-memory-descs (unwrap (read-u8 buffer 40)))
           (querylargeresp-num-descs (unwrap (read-u16be buffer 40)))
           (querylargeresp-data (unwrap (slice buffer 40 1)))
           (qos-real-dest-addr (unwrap (slice buffer 40 6)))
           (qos-real-src-addr (unwrap (slice buffer 40 6)))
           (qos-seq-num (unwrap (read-u16be buffer 40)))
           (qos-ready-sink-link-speed (unwrap (read-u32be buffer 40)))
           (qos-ready-perf-count-freq (unwrap (read-u64be buffer 40)))
           (qos-probe-controller-transmit-timestamp (unwrap (read-u64be buffer 40)))
           (qos-probe-sink-receive-timestamp (unwrap (read-u64be buffer 40)))
           (qos-probe-sink-transmit-timestamp (unwrap (read-u64be buffer 40)))
           (qos-probe-packet-id (unwrap (read-u8 buffer 40)))
           (qos-probe-t (unwrap (read-u8 buffer 40)))
           (qos-probe-8021p-value (unwrap (read-u8 buffer 40)))
           (qos-probe-payload (unwrap (slice buffer 40 5)))
           (qos-query-resp-r (unwrap (read-u8 buffer 40)))
           (qos-query-resp-e (unwrap (read-u8 buffer 40)))
           (qos-query-resp-num-events (unwrap (read-u16be buffer 40)))
           (qos-count-snapshot-history (unwrap (read-u8 buffer 58)))
           (qos-counter-result-subsec-span (unwrap (read-u8 buffer 58)))
