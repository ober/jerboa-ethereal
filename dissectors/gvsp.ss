        (cons 'gendc-payload-flow-id-v2-2 (list (cons 'raw gendc-payload-flow-id-v2-2) (cons 'formatted (number->string gendc-payload-flow-id-v2-2))))
        (cons 'gendc-container-header-signature-v2-2 (list (cons 'raw gendc-container-header-signature-v2-2) (cons 'formatted (utf8->string gendc-container-header-signature-v2-2))))
        (cons 'gendc-container-header-version-major-v2-2 (list (cons 'raw gendc-container-header-version-major-v2-2) (cons 'formatted (number->string gendc-container-header-version-major-v2-2))))
        (cons 'gendc-container-header-version-minor-v2-2 (list (cons 'raw gendc-container-header-version-minor-v2-2) (cons 'formatted (number->string gendc-container-header-version-minor-v2-2))))
        (cons 'gendc-container-header-version-sub-minor-v2-2 (list (cons 'raw gendc-container-header-version-sub-minor-v2-2) (cons 'formatted (number->string gendc-container-header-version-sub-minor-v2-2))))
        (cons 'gendc-header-reserved-1-byte-v2-2 (list (cons 'raw gendc-header-reserved-1-byte-v2-2) (cons 'formatted (fmt-hex gendc-header-reserved-1-byte-v2-2))))
        (cons 'gendc-container-header-flags-v2-2 (list (cons 'raw gendc-container-header-flags-v2-2) (cons 'formatted (fmt-hex gendc-container-header-flags-v2-2))))
        (cons 'gendc-container-header-flags-timestamp-ptp-v2-2 (list (cons 'raw gendc-container-header-flags-timestamp-ptp-v2-2) (cons 'formatted (if (= gendc-container-header-flags-timestamp-ptp-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-flags-component-invalid-v2-2 (list (cons 'raw gendc-container-header-flags-component-invalid-v2-2) (cons 'formatted (if (= gendc-container-header-flags-component-invalid-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-flags-reserved-v2-2 (list (cons 'raw gendc-container-header-flags-reserved-v2-2) (cons 'formatted (if (= gendc-container-header-flags-reserved-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-header-size-v2-2 (list (cons 'raw gendc-header-size-v2-2) (cons 'formatted (fmt-hex gendc-header-size-v2-2))))
        (cons 'gendc-container-header-id-v2-2 (list (cons 'raw gendc-container-header-id-v2-2) (cons 'formatted (fmt-hex gendc-container-header-id-v2-2))))
        (cons 'gendc-container-header-variable-fields-v2-2 (list (cons 'raw gendc-container-header-variable-fields-v2-2) (cons 'formatted (fmt-hex gendc-container-header-variable-fields-v2-2))))
        (cons 'gendc-container-header-variable-fields-data-size-v2-2 (list (cons 'raw gendc-container-header-variable-fields-data-size-v2-2) (cons 'formatted (if (= gendc-container-header-variable-fields-data-size-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-variable-fields-size-x-v2-2 (list (cons 'raw gendc-container-header-variable-fields-size-x-v2-2) (cons 'formatted (if (= gendc-container-header-variable-fields-size-x-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-variable-fields-size-y-v2-2 (list (cons 'raw gendc-container-header-variable-fields-size-y-v2-2) (cons 'formatted (if (= gendc-container-header-variable-fields-size-y-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-variable-fields-region-offset-v2-2 (list (cons 'raw gendc-container-header-variable-fields-region-offset-v2-2) (cons 'formatted (if (= gendc-container-header-variable-fields-region-offset-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-variable-fields-format-v2-2 (list (cons 'raw gendc-container-header-variable-fields-format-v2-2) (cons 'formatted (if (= gendc-container-header-variable-fields-format-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-variable-fields-timestamp-v2-2 (list (cons 'raw gendc-container-header-variable-fields-timestamp-v2-2) (cons 'formatted (if (= gendc-container-header-variable-fields-timestamp-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-variable-fields-component-count-v2-2 (list (cons 'raw gendc-container-header-variable-fields-component-count-v2-2) (cons 'formatted (if (= gendc-container-header-variable-fields-component-count-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-variable-fields-component-invalid-v2-2 (list (cons 'raw gendc-container-header-variable-fields-component-invalid-v2-2) (cons 'formatted (if (= gendc-container-header-variable-fields-component-invalid-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-container-header-variable-fields-reserved-v2-2 (list (cons 'raw gendc-container-header-variable-fields-reserved-v2-2) (cons 'formatted (if (= gendc-container-header-variable-fields-reserved-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-header-reserved-2-bytes-v2-2 (list (cons 'raw gendc-header-reserved-2-bytes-v2-2) (cons 'formatted (fmt-hex gendc-header-reserved-2-bytes-v2-2))))
        (cons 'gendc-header-reserved-4-bytes-v2-2 (list (cons 'raw gendc-header-reserved-4-bytes-v2-2) (cons 'formatted (fmt-hex gendc-header-reserved-4-bytes-v2-2))))
        (cons 'gendc-container-header-data-size-v2-2 (list (cons 'raw gendc-container-header-data-size-v2-2) (cons 'formatted (fmt-hex gendc-container-header-data-size-v2-2))))
        (cons 'gendc-container-header-data-offset-v2-2 (list (cons 'raw gendc-container-header-data-offset-v2-2) (cons 'formatted (fmt-hex gendc-container-header-data-offset-v2-2))))
        (cons 'gendc-container-header-descriptor-size-v2-2 (list (cons 'raw gendc-container-header-descriptor-size-v2-2) (cons 'formatted (fmt-hex gendc-container-header-descriptor-size-v2-2))))
        (cons 'gendc-container-header-component-count-v2-2 (list (cons 'raw gendc-container-header-component-count-v2-2) (cons 'formatted (fmt-hex gendc-container-header-component-count-v2-2))))
        (cons 'blockid16 (list (cons 'raw blockid16) (cons 'formatted (number->string blockid16))))
        (cons 'flags (list (cons 'raw flags) (cons 'formatted (fmt-hex flags))))
        (cons 'flagdevicespecific0 (list (cons 'raw flagdevicespecific0) (cons 'formatted (if (= flagdevicespecific0 0) "Not set" "Set"))))
        (cons 'flagdevicespecific1 (list (cons 'raw flagdevicespecific1) (cons 'formatted (if (= flagdevicespecific1 0) "Not set" "Set"))))
        (cons 'flagdevicespecific2 (list (cons 'raw flagdevicespecific2) (cons 'formatted (if (= flagdevicespecific2 0) "Not set" "Set"))))
        (cons 'flagdevicespecific3 (list (cons 'raw flagdevicespecific3) (cons 'formatted (if (= flagdevicespecific3 0) "Not set" "Set"))))
        (cons 'flagdevicespecific4 (list (cons 'raw flagdevicespecific4) (cons 'formatted (if (= flagdevicespecific4 0) "Not set" "Set"))))
        (cons 'flagdevicespecific5 (list (cons 'raw flagdevicespecific5) (cons 'formatted (if (= flagdevicespecific5 0) "Not set" "Set"))))
        (cons 'flagdevicespecific6 (list (cons 'raw flagdevicespecific6) (cons 'formatted (if (= flagdevicespecific6 0) "Not set" "Set"))))
        (cons 'flagdevicespecific7 (list (cons 'raw flagdevicespecific7) (cons 'formatted (if (= flagdevicespecific7 0) "Not set" "Set"))))
        (cons 'flagresendrangeerror (list (cons 'raw flagresendrangeerror) (cons 'formatted (if (= flagresendrangeerror 0) "Not set" "Set"))))
        (cons 'flagpreviousblockdropped (list (cons 'raw flagpreviousblockdropped) (cons 'formatted (if (= flagpreviousblockdropped 0) "Not set" "Set"))))
        (cons 'flagpacketresend (list (cons 'raw flagpacketresend) (cons 'formatted (if (= flagpacketresend 0) "Not set" "Set"))))
        (cons 'packetid24 (list (cons 'raw packetid24) (cons 'formatted (number->string packetid24))))
        (cons 'add-zones (list (cons 'raw add-zones) (cons 'formatted (fmt-hex add-zones))))
        (cons 'numparts (list (cons 'raw numparts) (cons 'formatted (number->string numparts))))
        (cons 'blockid64 (list (cons 'raw blockid64) (cons 'formatted (number->string blockid64))))
        (cons 'packetid32 (list (cons 'raw packetid32) (cons 'formatted (number->string packetid32))))
        )))

    (catch (e)
      (err (str "GVSP parse error: " e)))))

