        (cons 'gendc-payload-data-flag-end-of-descriptor-data-v2-2 (list (cons 'raw gendc-payload-data-flag-end-of-descriptor-data-v2-2) (cons 'formatted (if (= gendc-payload-data-flag-end-of-descriptor-data-v2-2 0) "Not set" "Set"))))
        (cons 'gendc-payload-data-flags-reserved-v2-2 (list (cons 'raw gendc-payload-data-flags-reserved-v2-2) (cons 'formatted (if (= gendc-payload-data-flags-reserved-v2-2 0) "Not set" "Set"))))
