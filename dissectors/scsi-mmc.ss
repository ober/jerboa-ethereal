        (cons 'mmc-disc-track-path (list (cons 'raw mmc-disc-track-path) (cons 'formatted (if (= mmc-disc-track-path 0) "Parallel Track Path" "Opposite Track Path"))))
        (cons 'mmc-disc-first-physical (list (cons 'raw mmc-disc-first-physical) (cons 'formatted (fmt-hex mmc-disc-first-physical))))
        (cons 'mmc-disc-last-physical (list (cons 'raw mmc-disc-last-physical) (cons 'formatted (fmt-hex mmc-disc-last-physical))))
        (cons 'mmc-disc-last-physical-layer0 (list (cons 'raw mmc-disc-last-physical-layer0) (cons 'formatted (fmt-hex mmc-disc-last-physical-layer0))))
        (cons 'mmc-disc-extended-format-info (list (cons 'raw mmc-disc-extended-format-info) (cons 'formatted (if (= mmc-disc-extended-format-info 0) "Data zone does NOT contain extended format info" "Data zone contains extended format info for VPCS"))))
        (cons 'mmc-adip-eib5 (list (cons 'raw mmc-adip-eib5) (cons 'formatted (number->string mmc-adip-eib5))))
