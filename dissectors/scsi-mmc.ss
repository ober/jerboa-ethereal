        (cons 'mmc-synccache-reladr (list (cons 'raw mmc-synccache-reladr) (cons 'formatted (number->string mmc-synccache-reladr))))
        (cons 'mmc-lba (list (cons 'raw mmc-lba) (cons 'formatted (number->string mmc-lba))))
