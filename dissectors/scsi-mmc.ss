(import (jerboa prelude))

;; ── Protocol Helpers ─────────────────────────────────────────────────
(def (read-u8 buf offset)
  (if (>= offset (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u8-ref buf offset))))

(def (read-u16be buf offset)
  (if (> (+ offset 2) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u16-ref buf offset (endianness big)))))

(def (read-u24be buf offset)
  (if (> (+ offset 3) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (+ (* (bytevector-u8-ref buf offset) 65536)
             (* (bytevector-u8-ref buf (+ offset 1)) 256)
             (bytevector-u8-ref buf (+ offset 2))))))

(def (read-u32be buf offset)
  (if (> (+ offset 4) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u32-ref buf offset (endianness big)))))

(def (read-u16le buf offset)
  (if (> (+ offset 2) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u16-ref buf offset (endianness little)))))

(def (read-u32le buf offset)
  (if (> (+ offset 4) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u32-ref buf offset (endianness little)))))

(def (read-u64be buf offset)
  (if (> (+ offset 8) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u64-ref buf offset (endianness big)))))

(def (read-u64le buf offset)
  (if (> (+ offset 8) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u64-ref buf offset (endianness little)))))

(def (slice buf offset len)
  (if (> (+ offset len) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (let ((result (make-bytevector len)))
            (bytevector-copy! buf offset result 0 len)
            result))))

(def (extract-bits val mask shift)
  (bitwise-arithmetic-shift-right (bitwise-and val mask) shift))

(def (fmt-ipv4 addr)
  (let ((b0 (bitwise-arithmetic-shift-right addr 24))
        (b1 (bitwise-and (bitwise-arithmetic-shift-right addr 16) 255))
        (b2 (bitwise-and (bitwise-arithmetic-shift-right addr 8) 255))
        (b3 (bitwise-and addr 255)))
    (str b0 "." b1 "." b2 "." b3)))

(def (fmt-mac bytes)
  (string-join
    (map (lambda (b) (string-pad (number->string b 16) 2 #\0))
         (bytevector->list bytes))
    ":"))

(def (fmt-hex val)
  (str "0x" (number->string val 16)))

(def (fmt-oct val)
  (str "0" (number->string val 8)))

(def (fmt-port port)
  (number->string port))

(def (fmt-bytes bv)
  (string-join
    (map (lambda (b) (string-pad (number->string b 16) 2 #\0))
         (bytevector->list bv))
    " "))

(def (fmt-ipv6-address bytes)
  (let loop ((i 0) (parts '()))
    (if (>= i 16)
        (string-join (reverse parts) ":")
        (loop (+ i 2)
              (cons (let ((w (+ (* (bytevector-u8-ref bytes i) 256)
                                (bytevector-u8-ref bytes (+ i 1)))))
                      (number->string w 16))
                    parts)))))

;; ── Dissector ──────────────────────────────────────────────────────
(def (dissect-scsi-mmc buffer)
  "SCSI_MMC"
  (try
    (let* (
           (mmc-read-dvd-address (unwrap (read-u32be buffer 0)))
           (mmc-read-dvd-layer-number (unwrap (read-u8 buffer 0)))
           (mmc-read-dvd-agid (unwrap (read-u8 buffer 0)))
           (mmc-disc-book-version (unwrap (read-u8 buffer 4)))
           (mmc-disc-track-path (unwrap (read-u8 buffer 4)))
           (mmc-disc-first-physical (unwrap (read-u24be buffer 4)))
           (mmc-disc-last-physical (unwrap (read-u24be buffer 4)))
           (mmc-disc-last-physical-layer0 (unwrap (read-u24be buffer 4)))
           (mmc-disc-extended-format-info (unwrap (read-u8 buffer 4)))
           (mmc-adip-eib5 (unwrap (read-u8 buffer 4)))
           (mmc-adip-eib4 (unwrap (read-u8 buffer 4)))
           (mmc-adip-eib3 (unwrap (read-u8 buffer 4)))
           (mmc-adip-eib2 (unwrap (read-u8 buffer 4)))
           (mmc-adip-eib1 (unwrap (read-u8 buffer 4)))
           (mmc-adip-eib0 (unwrap (read-u8 buffer 4)))
           (mmc-adip-device-manuf-id (unwrap (slice buffer 4 8)))
           (mmc-adip-media-type-id (unwrap (slice buffer 4 3)))
           (mmc-adip-product-revision-number (unwrap (read-u8 buffer 4)))
           (mmc-adip-number-of-physical-info (unwrap (read-u8 buffer 4)))
           (mmc-getperformance-data-type (unwrap (read-u8 buffer 4)))
           (mmc-getperformance-starting-lba (unwrap (read-u32be buffer 4)))
           (mmc-getperformance-max-num-descriptors (unwrap (read-u16be buffer 4)))
           (mmc-getperformance-type (unwrap (read-u8 buffer 4)))
           (mmc-synccache-immed (unwrap (read-u8 buffer 4)))
           (mmc-synccache-reladr (unwrap (read-u8 buffer 4)))
           (mmc-lba (unwrap (read-u32be buffer 4)))
           (mmc-num-blocks (unwrap (read-u32be buffer 4)))
           (mmc-agid (unwrap (read-u8 buffer 4)))
           (mmc-report-key-vendor-resets (unwrap (read-u8 buffer 4)))
           (mmc-report-key-user-changes (unwrap (read-u8 buffer 4)))
           (mmc-report-key-region-mask (unwrap (read-u8 buffer 4)))
           (mmc-gesn-polled (unwrap (read-u8 buffer 4)))
           (mmc-notification-flags (unwrap (read-u8 buffer 4)))
           (mmc-gesn-device-busy (extract-bits mmc-notification-flags 0x40 6))
           (mmc-gesn-multi-initiator (extract-bits mmc-notification-flags 0x20 5))
           (mmc-gesn-media (extract-bits mmc-notification-flags 0x10 4))
           (mmc-gesn-external-request (extract-bits mmc-notification-flags 0x8 3))
           (mmc-gesn-power-mgmt (extract-bits mmc-notification-flags 0x4 2))
           (mmc-gesn-operational-change (extract-bits mmc-notification-flags 0x2 1))
           (mmc-reservation-size (unwrap (read-u32be buffer 4)))
           (mmc-closetrack-immed (unwrap (read-u8 buffer 4)))
           (mmc-track (unwrap (read-u32be buffer 4)))
           (mmc-rbc-block (unwrap (read-u8 buffer 9)))
           (mmc-data-length (unwrap (read-u32be buffer 9)))
           (mmc-rbc-lob-blocks (unwrap (read-u32be buffer 9)))
           (mmc-rbc-alob-blocks (unwrap (read-u32be buffer 9)))
           (mmc-rbc-lob-bytes (unwrap (read-u32be buffer 9)))
           (mmc-rbc-alob-bytes (unwrap (read-u32be buffer 9)))
           (mmc-setcdspeed-logical-unit-read-speed (unwrap (read-u16be buffer 9)))
           (mmc-setcdspeed-logical-unit-write-speed (unwrap (read-u16be buffer 9)))
           (mmc-setstreaming-param-len (unwrap (read-u16be buffer 9)))
           (mmc-setstreaming-wrc (unwrap (read-u8 buffer 9)))
           (mmc-setstreaming-rdd (unwrap (read-u8 buffer 9)))
           (mmc-setstreaming-exact (unwrap (read-u8 buffer 9)))
           (mmc-setstreaming-ra (unwrap (read-u8 buffer 9)))
           (mmc-setstreaming-start-lba (unwrap (read-u32be buffer 9)))
           (mmc-setstreaming-end-lba (unwrap (read-u32be buffer 9)))
           (mmc-setstreaming-read-size (unwrap (read-u32be buffer 9)))
           (mmc-setstreaming-read-time (unwrap (read-u32be buffer 9)))
           (mmc-setstreaming-write-size (unwrap (read-u32be buffer 9)))
           (mmc-setstreaming-write-time (unwrap (read-u32be buffer 9)))
           (mmc-prevent-allow-flags (unwrap (read-u8 buffer 9)))
           (mmc-prevent-allow-persistent (extract-bits mmc-prevent-allow-flags 0x2 1))
           (mmc-prevent-allow-prevent (extract-bits mmc-prevent-allow-flags 0x1 0))
           )

      (ok (list
        (cons 'mmc-read-dvd-address (list (cons 'raw mmc-read-dvd-address) (cons 'formatted (number->string mmc-read-dvd-address))))
        (cons 'mmc-read-dvd-layer-number (list (cons 'raw mmc-read-dvd-layer-number) (cons 'formatted (number->string mmc-read-dvd-layer-number))))
