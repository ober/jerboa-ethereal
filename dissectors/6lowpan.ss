           (hc2-udp-dst (extract-bits hc2-udp-encoding 0x0 0))
           (hc2-udp-len (extract-bits hc2-udp-encoding 0x0 0))
           (iphc-sci (unwrap (read-u8 buffer 2)))
           (iphc-dci (unwrap (read-u8 buffer 2)))
           (mesh-orig64 (unwrap (read-u64be buffer 2)))
           (rfrag-ack-requested (unwrap (read-u8 buffer 2)))
           (rfrag-sequence (unwrap (read-u16be buffer 2)))
           (frag-dgram-tag (unwrap (read-u16be buffer 2)))
           (6lorhe-bitmap (unwrap (read-u32be buffer 3)))
           (ecn (unwrap (read-u8 buffer 3)))
           (dscp (unwrap (read-u8 buffer 3)))
           (padding (unwrap (read-u8 buffer 3)))
           (flow-label (unwrap (read-u24be buffer 3)))
           (next-header (unwrap (read-u8 buffer 3)))
           (pagenb (unwrap (read-u16be buffer 4)))
           (hop-limit (unwrap (read-u8 buffer 4)))
