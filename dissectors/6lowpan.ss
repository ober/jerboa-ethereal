           (dest (unwrap (slice buffer 5 16)))
           (nhc-ext-nh (unwrap (read-u8 buffer 6)))
           (6lorhe-length (unwrap (read-u16be buffer 7)))
           (6lorhe-hoplimit (unwrap (read-u8 buffer 7)))
           (6lorhc-address-src (unwrap (slice buffer 7 16)))
           (nhc-ext-next (unwrap (read-u8 buffer 7)))
           (nhc-ext-reserved (unwrap (read-u8 buffer 8)))
           (nhc-ext-length (unwrap (read-u8 buffer 8)))
           (nhc-udp-checksum (unwrap (read-u8 buffer 9)))
           (udp-src (unwrap (read-u16be buffer 10)))
