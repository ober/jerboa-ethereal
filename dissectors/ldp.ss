        (cons 'tlv-sess-atm-lr (list (cons 'raw tlv-sess-atm-lr) (cons 'formatted (number->string tlv-sess-atm-lr))))
        (cons 'tlv-sess-atm-dir (list (cons 'raw tlv-sess-atm-dir) (cons 'formatted (if (= tlv-sess-atm-dir 0) "Unidirectional capability" "Bidirectional capability"))))
        (cons 'tlv-sess-atm-minvpi (list (cons 'raw tlv-sess-atm-minvpi) (cons 'formatted (number->string tlv-sess-atm-minvpi))))
        (cons 'tlv-sess-atm-minvci (list (cons 'raw tlv-sess-atm-minvci) (cons 'formatted (number->string tlv-sess-atm-minvci))))
        (cons 'tlv-sess-atm-maxvci (list (cons 'raw tlv-sess-atm-maxvci) (cons 'formatted (number->string tlv-sess-atm-maxvci))))
        (cons 'tlv-sess-fr-lr (list (cons 'raw tlv-sess-fr-lr) (cons 'formatted (number->string tlv-sess-fr-lr))))
        (cons 'tlv-sess-fr-dir (list (cons 'raw tlv-sess-fr-dir) (cons 'formatted (if (= tlv-sess-fr-dir 0) "Unidirectional capability" "Bidirectional capability"))))
        (cons 'tlv-sess-fr-mindlci (list (cons 'raw tlv-sess-fr-mindlci) (cons 'formatted (number->string tlv-sess-fr-mindlci))))
        (cons 'tlv-sess-fr-maxdlci (list (cons 'raw tlv-sess-fr-maxdlci) (cons 'formatted (number->string tlv-sess-fr-maxdlci))))
        (cons 'tlv-ft-sess-flags (list (cons 'raw tlv-ft-sess-flags) (cons 'formatted (fmt-hex tlv-ft-sess-flags))))
        (cons 'tlv-ft-sess-flag-r (list (cons 'raw tlv-ft-sess-flag-r) (cons 'formatted (if (= tlv-ft-sess-flag-r 0) "LSR has not preserved state and resources for all FT-Labels" "LSR has preserved state and resources for all FT-Labels"))))
        (cons 'tlv-ft-sess-flag-res (list (cons 'raw tlv-ft-sess-flag-res) (cons 'formatted (fmt-hex tlv-ft-sess-flag-res))))
        (cons 'tlv-ft-sess-flag-s (list (cons 'raw tlv-ft-sess-flag-s) (cons 'formatted (if (= tlv-ft-sess-flag-s 0) "FT Protection TLV not supported on other than KeepAlive" "FT Protection TLV supported on other than KeepAlive"))))
        (cons 'tlv-ft-sess-flag-a (list (cons 'raw tlv-ft-sess-flag-a) (cons 'formatted (if (= tlv-ft-sess-flag-a 0) "May treat some labels as FT and others as non-FT" "Treat all labels as Sequence Numbered FT Labels"))))
        (cons 'tlv-ft-sess-flag-c (list (cons 'raw tlv-ft-sess-flag-c) (cons 'formatted (if (= tlv-ft-sess-flag-c 0) "Check-Pointing procedures not in use" "Check-Pointing procedures in use"))))
        (cons 'tlv-ft-sess-flag-l (list (cons 'raw tlv-ft-sess-flag-l) (cons 'formatted (if (= tlv-ft-sess-flag-l 0) "Do not re-learn the state from the network" "Re-learn the state from the network"))))
        (cons 'tlv-ft-sess-res (list (cons 'raw tlv-ft-sess-res) (cons 'formatted (fmt-hex tlv-ft-sess-res))))
        (cons 'tlv-ft-sess-reconn-to (list (cons 'raw tlv-ft-sess-reconn-to) (cons 'formatted (number->string tlv-ft-sess-reconn-to))))
        (cons 'tlv-ft-sess-recovery-time (list (cons 'raw tlv-ft-sess-recovery-time) (cons 'formatted (number->string tlv-ft-sess-recovery-time))))
        (cons 'tlv-lspid-cr-lsp (list (cons 'raw tlv-lspid-cr-lsp) (cons 'formatted (fmt-hex tlv-lspid-cr-lsp))))
        (cons 'tlv-lspid-ldpid (list (cons 'raw tlv-lspid-ldpid) (cons 'formatted (fmt-ipv4 tlv-lspid-ldpid))))
        (cons 'tlv-er-hop-prefix4 (list (cons 'raw tlv-er-hop-prefix4) (cons 'formatted (fmt-ipv4 tlv-er-hop-prefix4))))
        (cons 'tlv-er-hop-prelen (list (cons 'raw tlv-er-hop-prelen) (cons 'formatted (number->string tlv-er-hop-prelen))))
        (cons 'tlv-er-hop-prefix6 (list (cons 'raw tlv-er-hop-prefix6) (cons 'formatted (fmt-ipv6-address tlv-er-hop-prefix6))))
        (cons 'tlv-er-hop-as (list (cons 'raw tlv-er-hop-as) (cons 'formatted (number->string tlv-er-hop-as))))
        (cons 'tlv-er-hop-cr-lsp (list (cons 'raw tlv-er-hop-cr-lsp) (cons 'formatted (number->string tlv-er-hop-cr-lsp))))
        (cons 'tlv-er-hop-ldpid (list (cons 'raw tlv-er-hop-ldpid) (cons 'formatted (fmt-ipv4 tlv-er-hop-ldpid))))
        (cons 'tlv-flags-reserv (list (cons 'raw tlv-flags-reserv) (cons 'formatted (fmt-hex tlv-flags-reserv))))
        (cons 'tlv-flags-weight (list (cons 'raw tlv-flags-weight) (cons 'formatted (if (= tlv-flags-weight 0) "Not negotiable" "Negotiable"))))
        (cons 'tlv-flags-ebs (list (cons 'raw tlv-flags-ebs) (cons 'formatted (if (= tlv-flags-ebs 0) "Not negotiable" "Negotiable"))))
        (cons 'tlv-flags-cbs (list (cons 'raw tlv-flags-cbs) (cons 'formatted (if (= tlv-flags-cbs 0) "Not negotiable" "Negotiable"))))
        (cons 'tlv-flags-cdr (list (cons 'raw tlv-flags-cdr) (cons 'formatted (if (= tlv-flags-cdr 0) "Not negotiable" "Negotiable"))))
        (cons 'tlv-flags-pbs (list (cons 'raw tlv-flags-pbs) (cons 'formatted (if (= tlv-flags-pbs 0) "Not negotiable" "Negotiable"))))
        (cons 'tlv-flags-pdr (list (cons 'raw tlv-flags-pdr) (cons 'formatted (if (= tlv-flags-pdr 0) "Not negotiable" "Negotiable"))))
        (cons 'tlv-weight (list (cons 'raw tlv-weight) (cons 'formatted (number->string tlv-weight))))
        (cons 'tlv-pdr (list (cons 'raw tlv-pdr) (cons 'formatted (number->string tlv-pdr))))
        (cons 'tlv-pbs (list (cons 'raw tlv-pbs) (cons 'formatted (number->string tlv-pbs))))
        (cons 'tlv-cdr (list (cons 'raw tlv-cdr) (cons 'formatted (number->string tlv-cdr))))
        (cons 'tlv-cbs (list (cons 'raw tlv-cbs) (cons 'formatted (number->string tlv-cbs))))
        (cons 'tlv-ebs (list (cons 'raw tlv-ebs) (cons 'formatted (number->string tlv-ebs))))
        (cons 'tlv-resource-class (list (cons 'raw tlv-resource-class) (cons 'formatted (fmt-hex tlv-resource-class))))
        (cons 'tlv-set-prio (list (cons 'raw tlv-set-prio) (cons 'formatted (number->string tlv-set-prio))))
        (cons 'tlv-hold-prio (list (cons 'raw tlv-hold-prio) (cons 'formatted (number->string tlv-hold-prio))))
        (cons 'tlv-diffserv-mapnb (list (cons 'raw tlv-diffserv-mapnb) (cons 'formatted (number->string tlv-diffserv-mapnb))))
        (cons 'tlv-inv-length (list (cons 'raw tlv-inv-length) (cons 'formatted (fmt-hex tlv-inv-length))))
        (cons 'tlv-upstr-sbit (list (cons 'raw tlv-upstr-sbit) (cons 'formatted (if (= tlv-upstr-sbit 0) "LSR is withdrawing the capability to distribute and receive upstream-assigned label bindings" "LSR is advertising the capability to distribute and receive upstream-assigned label bindings"))))
        (cons 'tlv-upstr-lbl-req-resvbit (list (cons 'raw tlv-upstr-lbl-req-resvbit) (cons 'formatted (fmt-hex tlv-upstr-lbl-req-resvbit))))
        (cons 'tlv-upstr-lbl-resvbit (list (cons 'raw tlv-upstr-lbl-resvbit) (cons 'formatted (fmt-hex tlv-upstr-lbl-resvbit))))
        (cons 'tlv-upstr-ass-lbl (list (cons 'raw tlv-upstr-ass-lbl) (cons 'formatted (fmt-hex tlv-upstr-ass-lbl))))
        (cons 'tlv-ipv4-intID-hop-addr (list (cons 'raw tlv-ipv4-intID-hop-addr) (cons 'formatted (fmt-ipv4 tlv-ipv4-intID-hop-addr))))
        (cons 'tlv-logical-intID (list (cons 'raw tlv-logical-intID) (cons 'formatted (fmt-hex tlv-logical-intID))))
        (cons 'tlv-ip-multicast-srcaddr (list (cons 'raw tlv-ip-multicast-srcaddr) (cons 'formatted (fmt-ipv4 tlv-ip-multicast-srcaddr))))
        (cons 'tlv-ip-multicast-mltcstaddr (list (cons 'raw tlv-ip-multicast-mltcstaddr) (cons 'formatted (fmt-ipv4 tlv-ip-multicast-mltcstaddr))))
        (cons 'tlv-ip-mpls-context-srcaddr (list (cons 'raw tlv-ip-mpls-context-srcaddr) (cons 'formatted (fmt-ipv4 tlv-ip-mpls-context-srcaddr))))
        (cons 'tlv-ldp-p2mp-lsptype (list (cons 'raw tlv-ldp-p2mp-lsptype) (cons 'formatted (fmt-hex tlv-ldp-p2mp-lsptype))))
        (cons 'tlv-ldp-p2mp-addrfam (list (cons 'raw tlv-ldp-p2mp-addrfam) (cons 'formatted (fmt-hex tlv-ldp-p2mp-addrfam))))
        (cons 'tlv-ldp-p2mp-addrlen (list (cons 'raw tlv-ldp-p2mp-addrlen) (cons 'formatted (fmt-hex tlv-ldp-p2mp-addrlen))))
        (cons 'tlv-ldp-p2mp-rtnodeaddr (list (cons 'raw tlv-ldp-p2mp-rtnodeaddr) (cons 'formatted (fmt-ipv4 tlv-ldp-p2mp-rtnodeaddr))))
        (cons 'tlv-rsvp-te-p2mp-id (list (cons 'raw tlv-rsvp-te-p2mp-id) (cons 'formatted (fmt-hex tlv-rsvp-te-p2mp-id))))
        (cons 'tlv-must-be-zero (list (cons 'raw tlv-must-be-zero) (cons 'formatted (fmt-hex tlv-must-be-zero))))
        (cons 'tlv-tunnel-id (list (cons 'raw tlv-tunnel-id) (cons 'formatted (fmt-hex tlv-tunnel-id))))
        (cons 'tlv-ext-tunnel-id (list (cons 'raw tlv-ext-tunnel-id) (cons 'formatted (fmt-ipv4 tlv-ext-tunnel-id))))
        (cons 'tlv-len (list (cons 'raw tlv-len) (cons 'formatted (number->string tlv-len))))
        (cons 'tlv-hc-value (list (cons 'raw tlv-hc-value) (cons 'formatted (number->string tlv-hc-value))))
        (cons 'tlv-generic-label (list (cons 'raw tlv-generic-label) (cons 'formatted (number->string tlv-generic-label))))
        (cons 'tlv-ft-protect-sequence-num (list (cons 'raw tlv-ft-protect-sequence-num) (cons 'formatted (fmt-hex tlv-ft-protect-sequence-num))))
        (cons 'tlv-extstatus-data (list (cons 'raw tlv-extstatus-data) (cons 'formatted (fmt-hex tlv-extstatus-data))))
        (cons 'tlv-ipv4-taddr (list (cons 'raw tlv-ipv4-taddr) (cons 'formatted (fmt-ipv4 tlv-ipv4-taddr))))
        (cons 'tlv-config-seqno (list (cons 'raw tlv-config-seqno) (cons 'formatted (number->string tlv-config-seqno))))
        (cons 'tlv-ipv6-taddr (list (cons 'raw tlv-ipv6-taddr) (cons 'formatted (fmt-ipv6-address tlv-ipv6-taddr))))
        (cons 'tlv-ft-ack-sequence-num (list (cons 'raw tlv-ft-ack-sequence-num) (cons 'formatted (fmt-hex tlv-ft-ack-sequence-num))))
        (cons 'tlv-lbl-req-msg-id (list (cons 'raw tlv-lbl-req-msg-id) (cons 'formatted (fmt-hex tlv-lbl-req-msg-id))))
        (cons 'tlv-vendor-id (list (cons 'raw tlv-vendor-id) (cons 'formatted (fmt-hex tlv-vendor-id))))
        (cons 'data (list (cons 'raw data) (cons 'formatted (fmt-bytes data))))
        (cons 'tlv-experiment-id (list (cons 'raw tlv-experiment-id) (cons 'formatted (fmt-hex tlv-experiment-id))))
        (cons 'tlv-value (list (cons 'raw tlv-value) (cons 'formatted (fmt-bytes tlv-value))))
        (cons 'msg-ubit (list (cons 'raw msg-ubit) (cons 'formatted (if (= msg-ubit 0) "Unknown bit not set" "Unknown bit set"))))
        (cons 'msg-len (list (cons 'raw msg-len) (cons 'formatted (number->string msg-len))))
        (cons 'msg-id (list (cons 'raw msg-id) (cons 'formatted (fmt-hex msg-id))))
        )))

    (catch (e)
      (err (str "LDP parse error: " e)))))

