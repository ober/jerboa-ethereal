        (cons 'tlv-mac (list (cons 'raw tlv-mac) (cons 'formatted (fmt-mac tlv-mac))))
        (cons 'tlv-sess-ver (list (cons 'raw tlv-sess-ver) (cons 'formatted (number->string tlv-sess-ver))))
        (cons 'tlv-sess-ka (list (cons 'raw tlv-sess-ka) (cons 'formatted (number->string tlv-sess-ka))))
        (cons 'tlv-sess-advbit (list (cons 'raw tlv-sess-advbit) (cons 'formatted (if (= tlv-sess-advbit 0) "Downstream Unsolicited proposed" "Downstream On Demand proposed"))))
        (cons 'tlv-sess-ldetbit (list (cons 'raw tlv-sess-ldetbit) (cons 'formatted (if (= tlv-sess-ldetbit 0) "Loop Detection Disabled" "Loop Detection Enabled"))))
