        (cons 'ses-rsp-read-req-message-id (list (cons 'raw ses-rsp-read-req-message-id) (cons 'formatted (number->string ses-rsp-read-req-message-id))))
        (cons 'ses-rsp-reserved2 (list (cons 'raw ses-rsp-reserved2) (cons 'formatted (fmt-hex ses-rsp-reserved2))))
        (cons 'ses-rsp-mod-length (list (cons 'raw ses-rsp-mod-length) (cons 'formatted (number->string ses-rsp-mod-length))))
        (cons 'ses-rsp-message-offset (list (cons 'raw ses-rsp-message-offset) (cons 'formatted (number->string ses-rsp-message-offset))))
        (cons 'ses-rsp-list (list (cons 'raw ses-rsp-list) (cons 'formatted (number->string ses-rsp-list))))
        (cons 'ses-rsp-ver (list (cons 'raw ses-rsp-ver) (cons 'formatted (number->string ses-rsp-ver))))
        (cons 'ses-rsp-reserved3 (list (cons 'raw ses-rsp-reserved3) (cons 'formatted (fmt-hex ses-rsp-reserved3))))
        (cons 'ses-rsp-payload-length (list (cons 'raw ses-rsp-payload-length) (cons 'formatted (number->string ses-rsp-payload-length))))
        (cons 'ses-prlg (list (cons 'raw ses-prlg) (cons 'formatted (fmt-bytes ses-prlg))))
        (cons 'pds-clear-psn (list (cons 'raw pds-clear-psn) (cons 'formatted (number->string pds-clear-psn))))
        (cons 'pds-pdc-mode (list (cons 'raw pds-pdc-mode) (cons 'formatted (number->string pds-pdc-mode))))
        (cons 'pds-pdc-mode-use-rsv (list (cons 'raw pds-pdc-mode-use-rsv) (cons 'formatted (if (= pds-pdc-mode-use-rsv 0) "False" "True"))))
        (cons 'pds-pdc-mode-rsv (list (cons 'raw pds-pdc-mode-rsv) (cons 'formatted (fmt-hex pds-pdc-mode-rsv))))
        (cons 'pds-psn-offset (list (cons 'raw pds-psn-offset) (cons 'formatted (number->string pds-psn-offset))))
        (cons 'pds-start-psn (list (cons 'raw pds-start-psn) (cons 'formatted (number->string pds-start-psn))))
        (cons 'pds-req-cc-state-ccc-id (list (cons 'raw pds-req-cc-state-ccc-id) (cons 'formatted (number->string pds-req-cc-state-ccc-id))))
        (cons 'pds-req-cc-state-credit-target (list (cons 'raw pds-req-cc-state-credit-target) (cons 'formatted (fmt-hex pds-req-cc-state-credit-target))))
        (cons 'pds-rudi-pkt-id (list (cons 'raw pds-rudi-pkt-id) (cons 'formatted (number->string pds-rudi-pkt-id))))
        (cons 'pds-ctl-probe-opaque (list (cons 'raw pds-ctl-probe-opaque) (cons 'formatted (fmt-hex pds-ctl-probe-opaque))))
        (cons 'pds-psn (list (cons 'raw pds-psn) (cons 'formatted (number->string pds-psn))))
        (cons 'pds-ctl-payload (list (cons 'raw pds-ctl-payload) (cons 'formatted (fmt-hex pds-ctl-payload))))
        (cons 'pds-ack-prlg (list (cons 'raw pds-ack-prlg) (cons 'formatted (fmt-bytes pds-ack-prlg))))
        (cons 'pds-ack-cc-type (list (cons 'raw pds-ack-cc-type) (cons 'formatted (number->string pds-ack-cc-type))))
        (cons 'pds-ack-mpr (list (cons 'raw pds-ack-mpr) (cons 'formatted (number->string pds-ack-mpr))))
        (cons 'pds-ack-sack-offset (list (cons 'raw pds-ack-sack-offset) (cons 'formatted (number->string pds-ack-sack-offset))))
        (cons 'pds-ack-sack-bitmap (list (cons 'raw pds-ack-sack-bitmap) (cons 'formatted (fmt-hex pds-ack-sack-bitmap))))
        (cons 'pds-ack-cc-state (list (cons 'raw pds-ack-cc-state) (cons 'formatted (fmt-bytes pds-ack-cc-state))))
        (cons 'pds-ack-cc-state-service-time (list (cons 'raw pds-ack-cc-state-service-time) (cons 'formatted (number->string pds-ack-cc-state-service-time))))
        (cons 'pds-ack-cc-state-rc (list (cons 'raw pds-ack-cc-state-rc) (cons 'formatted (number->string pds-ack-cc-state-rc))))
        (cons 'pds-ack-cc-state-rcv-cwnd-pend (list (cons 'raw pds-ack-cc-state-rcv-cwnd-pend) (cons 'formatted (number->string pds-ack-cc-state-rcv-cwnd-pend))))
        (cons 'pds-ack-cc-state-rcvd-bytes (list (cons 'raw pds-ack-cc-state-rcvd-bytes) (cons 'formatted (number->string pds-ack-cc-state-rcvd-bytes))))
        (cons 'pds-ack-cc-state-ooo-count (list (cons 'raw pds-ack-cc-state-ooo-count) (cons 'formatted (number->string pds-ack-cc-state-ooo-count))))
        (cons 'pds-ack-cc-state-credit (list (cons 'raw pds-ack-cc-state-credit) (cons 'formatted (number->string pds-ack-cc-state-credit))))
        (cons 'pds-ack-cc-state-reserved (list (cons 'raw pds-ack-cc-state-reserved) (cons 'formatted (fmt-bytes pds-ack-cc-state-reserved))))
        (cons 'pds-ack-ccx-state (list (cons 'raw pds-ack-ccx-state) (cons 'formatted (fmt-bytes pds-ack-ccx-state))))
        (cons 'pds-ack-psn (list (cons 'raw pds-ack-psn) (cons 'formatted (number->string pds-ack-psn))))
        (cons 'pds-cack-psn (list (cons 'raw pds-cack-psn) (cons 'formatted (number->string pds-cack-psn))))
        (cons 'pds-nack-vendor-code (list (cons 'raw pds-nack-vendor-code) (cons 'formatted (number->string pds-nack-vendor-code))))
        (cons 'pds-nack-psn (list (cons 'raw pds-nack-psn) (cons 'formatted (number->string pds-nack-psn))))
        (cons 'pds-spdcid (list (cons 'raw pds-spdcid) (cons 'formatted (number->string pds-spdcid))))
        (cons 'pds-dpdcid (list (cons 'raw pds-dpdcid) (cons 'formatted (number->string pds-dpdcid))))
        (cons 'pds-nack-max-recv-psn (list (cons 'raw pds-nack-max-recv-psn) (cons 'formatted (number->string pds-nack-max-recv-psn))))
        (cons 'pds-flags (list (cons 'raw pds-flags) (cons 'formatted (fmt-hex pds-flags))))
        (cons 'pds-flags-retx (list (cons 'raw pds-flags-retx) (cons 'formatted (if (= pds-flags-retx 0) "Not set" "Set"))))
        (cons 'pds-flags-ar (list (cons 'raw pds-flags-ar) (cons 'formatted (if (= pds-flags-ar 0) "Not set" "Set"))))
        (cons 'pds-flags-syn (list (cons 'raw pds-flags-syn) (cons 'formatted (if (= pds-flags-syn 0) "Not set" "Set"))))
        (cons 'pds-flags-rsvd-ctl (list (cons 'raw pds-flags-rsvd-ctl) (cons 'formatted (if (= pds-flags-rsvd-ctl 0) "Not set" "Set"))))
        (cons 'pds-flags-rsvd-rudi (list (cons 'raw pds-flags-rsvd-rudi) (cons 'formatted (fmt-hex pds-flags-rsvd-rudi))))
        (cons 'pds-flags-rsvd-uud (list (cons 'raw pds-flags-rsvd-uud) (cons 'formatted (fmt-hex pds-flags-rsvd-uud))))
        (cons 'pds-prlg (list (cons 'raw pds-prlg) (cons 'formatted (fmt-bytes pds-prlg))))
        )))

    (catch (e)
      (err (str "UET parse error: " e)))))

;; dissect-uet: parse UET from bytevector
;; Returns (ok fields-alist) or (err message)