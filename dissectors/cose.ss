;; packet-cose.c
;; Routines for CBOR Object Signing and Encryption (COSE) dissection
;; References:
;; RFC 8949: https://tools.ietf.org/html/rfc8949
;; RFC 9052: https://tools.ietf.org/html/rfc9052
;; RFC 9053: https://tools.ietf.org/html/rfc9053
