           (reqack-flag (extract-bits flagmask 0x0 0))
           (ack-flag (extract-bits flagmask 0x0 0))
           (info-flag (extract-bits flagmask 0x0 0))
           (error-flag (extract-bits flagmask 0x0 0))
           (guaranteed-flag (extract-bits flagmask 0x0 0))
           (multipart-flag (extract-bits flagmask 0x0 0))
           (session-number-flag (extract-bits flagmask 0x0 0))
           (sensrate (unwrap (read-u16be buffer 57)))
           (subflags (unwrap (read-u16be buffer 59)))
           (subtype (unwrap (read-u8 buffer 65)))
           (numvds (unwrap (read-u16be buffer 75)))
           (vdaddr (unwrap (read-u8 buffer 77)))
           (vdclassid (unwrap (read-u16be buffer 78)))
           (strnum (unwrap (read-u16be buffer 81)))
           (recnum (unwrap (read-u16be buffer 86)))
           (strlen (unwrap (read-u16be buffer 88)))
           (wrkgrppath (unwrap (slice buffer 90 1)))
           (scope (unwrap (read-u8 buffer 90)))
           (maxdatasize (unwrap (read-u16be buffer 92)))
           (catfilter (unwrap (read-u32be buffer 94)))
           (app-cat (extract-bits catfilter 0x0 0))
           (conf-cat (extract-bits catfilter 0x0 0))
           (audionet-cat (extract-bits catfilter 0x0 0))
           (ctrlnet-cat (extract-bits catfilter 0x0 0))
           (vendnet-cat (extract-bits catfilter 0x0 0))
           (startup-cat (extract-bits catfilter 0x0 0))
           (dsp-cat (extract-bits catfilter 0x0 0))
