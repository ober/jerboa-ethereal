           (ctrlog-cat (extract-bits catfilter 0x0 0))
           (foreignproto-cat (extract-bits catfilter 0x0 0))
           (digio-cat (extract-bits catfilter 0x0 0))
           (ctrlsurf-cat (extract-bits catfilter 0x0 0))
           (entrieslen (unwrap (read-u16be buffer 94)))
           (eventseqnum (unwrap (read-u32be buffer 101)))
           (eventtime (unwrap (slice buffer 105 1)))
           (eventdate (unwrap (slice buffer 105 1)))
           (eventinfo (unwrap (slice buffer 105 1)))
           (eventadddata (unwrap (slice buffer 105 1)))
           (pubparmid (unwrap (read-u16be buffer 107)))
           (subparmid (unwrap (read-u16be buffer 109)))
           (objcount (unwrap (read-u16be buffer 111)))
           (paramcount (unwrap (read-u16be buffer 121)))
           (paramid (unwrap (read-u16be buffer 123)))
           (paramval (unwrap (read-u16be buffer 125)))
           (subcount (unwrap (read-u16be buffer 127)))
           (ifacecount (unwrap (read-u16be buffer 129)))
           (maxmsgsize (unwrap (read-u32be buffer 131)))
           (devaddr (unwrap (read-u16be buffer 135)))
           (newdevaddr (unwrap (read-u16be buffer 135)))
           (attrcount (unwrap (read-u16be buffer 137)))
           (version (unwrap (read-u8 buffer 139)))
           )

      (ok (list
        (cons 'headerlen (list (cons 'raw headerlen) (cons 'formatted (number->string headerlen))))
        (cons 'messagelen (list (cons 'raw messagelen) (cons 'formatted (number->string messagelen))))
        (cons 'sourcedev (list (cons 'raw sourcedev) (cons 'formatted (number->string sourcedev))))
