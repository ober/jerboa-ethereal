           (lndie-discovery-slots (unwrap (read-u8 buffer 6)))
           (lndie-discovery-first-slot (unwrap (read-u16be buffer 6)))
           (ltoie-offset (unwrap (read-u24be buffer 6)))
           (ltoie-listening-interval (unwrap (read-u24be buffer 6)))
           (panidie-panid (unwrap (read-u16be buffer 6)))
           (rtie-rendezvous-time (unwrap (read-u16be buffer 6)))
           (rtie-wakeup-interval (unwrap (read-u16be buffer 6)))
           (lbcie-broadcast-interval (unwrap (read-u24be buffer 6)))
           (lbcie-broadcast-sync-period (unwrap (read-u8 buffer 6)))
           (netricity-lqiie-lqi (unwrap (read-u8 buffer 6)))
           (usie-number-channels (unwrap (read-u16be buffer 6)))
           (bsie-bcast-schedule-id (unwrap (read-u16be buffer 6)))
           (panie-flags (unwrap (read-u8 buffer 6)))
           (panie-flag-parent-bsie (extract-bits panie-flags 0x1 0))
           (panie-flag-version (extract-bits panie-flags 0xE0 5))
           (usie-fixed-channel (unwrap (read-u16be buffer 8)))
           (eapol-relay-direction (unwrap (read-u8 buffer 9)))
           (gtkhashie-gtk1 (unwrap (slice buffer 10 8)))
           (usie-hop-count (unwrap (read-u8 buffer 10)))
           (usie-hop-list (unwrap (read-u8 buffer 10)))
           (usie-number-ranges (unwrap (read-u8 buffer 10)))
           (usie-exclude-range-start (unwrap (read-u16be buffer 10)))
           (lgtkhashie-gtk1 (unwrap (slice buffer 10 8)))
           (usie-exclude-range-end (unwrap (read-u16be buffer 12)))
           (usie-exclude-mask (unwrap (slice buffer 14 1)))
           (usie-timing-accuracy (unwrap (read-u8 buffer 14)))
           (gtkhashie-gtk2 (unwrap (slice buffer 18 8)))
           (lgtkhashie-gtk2 (unwrap (slice buffer 18 8)))
           (gtkhashie-gtk3 (unwrap (slice buffer 26 8)))
           (wsie (unwrap (read-u16le buffer 34)))
           (wsie-length (extract-bits wsie 0x0 0))
