        (cons 'netricity-sc-segment-length (list (cons 'raw netricity-sc-segment-length) (cons 'formatted (number->string netricity-sc-segment-length))))
        (cons 'sec-error-nonce (list (cons 'raw sec-error-nonce) (cons 'formatted (fmt-bytes sec-error-nonce))))
