           (usie-explicit (unwrap (read-u32le buffer 3)))
           (usie-explicit-reserved (extract-bits usie-explicit 0x0 0))
           (panie-cost (unwrap (read-u16be buffer 4)))
           (jmie-metric-hdr (unwrap (read-u8 buffer 4)))
           (lusie-listen-interval (unwrap (read-u24be buffer 6)))
           (lusie-channel-plan-tag (unwrap (read-u8 buffer 6)))
           (lbtie-slot (unwrap (read-u24be buffer 6)))
