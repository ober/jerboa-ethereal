        (cons 'ehdr-flow-id-source-id (list (cons 'raw ehdr-flow-id-source-id) (cons 'formatted (number->string ehdr-flow-id-source-id))))
        (cons 'ehdr-anchor-id-anchorid (list (cons 'raw ehdr-anchor-id-anchorid) (cons 'formatted (fmt-hex ehdr-anchor-id-anchorid))))
        (cons 'ehdr-host-id-hostid (list (cons 'raw ehdr-host-id-hostid) (cons 'formatted (fmt-hex ehdr-host-id-hostid))))
        (cons 'ehdr-host-id-sourceid (list (cons 'raw ehdr-host-id-sourceid) (cons 'formatted (number->string ehdr-host-id-sourceid))))
        (cons 'ehdr-signature-flow-hash (list (cons 'raw ehdr-signature-flow-hash) (cons 'formatted (fmt-hex ehdr-signature-flow-hash))))
        (cons 'ehdr-signature-color (list (cons 'raw ehdr-signature-color) (cons 'formatted (fmt-hex ehdr-signature-color))))
        (cons 'ehdr-signature-payload-hash (list (cons 'raw ehdr-signature-payload-hash) (cons 'formatted (fmt-hex ehdr-signature-payload-hash))))
        (cons 'ehdr-chan-virt-container-id (list (cons 'raw ehdr-chan-virt-container-id) (cons 'formatted (fmt-hex ehdr-chan-virt-container-id))))
        (cons 'ehdr-chan-res (list (cons 'raw ehdr-chan-res) (cons 'formatted (fmt-hex ehdr-chan-res))))
        (cons 'ehdr-chan-seqnum (list (cons 'raw ehdr-chan-seqnum) (cons 'formatted (number->string ehdr-chan-seqnum))))
        (cons 'ehdr-chan-morefrag (list (cons 'raw ehdr-chan-morefrag) (cons 'formatted (number->string ehdr-chan-morefrag))))
        (cons 'ehdr-chan-morebits (list (cons 'raw ehdr-chan-morebits) (cons 'formatted (number->string ehdr-chan-morebits))))
        (cons 'ehdr-bfs-raw-hash (list (cons 'raw ehdr-bfs-raw-hash) (cons 'formatted (fmt-hex ehdr-bfs-raw-hash))))
        (cons 'ehdr-bfs-color (list (cons 'raw ehdr-bfs-color) (cons 'formatted (fmt-hex ehdr-bfs-color))))
        (cons 'ehdr-bfs-hash (list (cons 'raw ehdr-bfs-hash) (cons 'formatted (fmt-hex ehdr-bfs-hash))))
        (cons 'ehdr-raw-link-seqnum (list (cons 'raw ehdr-raw-link-seqnum) (cons 'formatted (number->string ehdr-raw-link-seqnum))))
        (cons 'ehdr-raw-link-res (list (cons 'raw ehdr-raw-link-res) (cons 'formatted (fmt-hex ehdr-raw-link-res))))
        (cons 'ehdr-int-res2 (list (cons 'raw ehdr-int-res2) (cons 'formatted (fmt-hex ehdr-int-res2))))
        (cons 'ehdr-int-id (list (cons 'raw ehdr-int-id) (cons 'formatted (number->string ehdr-int-id))))
        (cons 'ehdr-int-res1 (list (cons 'raw ehdr-int-res1) (cons 'formatted (fmt-hex ehdr-int-res1))))
        (cons 'ehdr-class-seqnum (list (cons 'raw ehdr-class-seqnum) (cons 'formatted (number->string ehdr-class-seqnum))))
        (cons 'ehdr-class-flags-str (list (cons 'raw ehdr-class-flags-str) (cons 'formatted (number->string ehdr-class-flags-str))))
        (cons 'ehdr-class-flags-drop (list (cons 'raw ehdr-class-flags-drop) (cons 'formatted (number->string ehdr-class-flags-drop))))
        (cons 'ehdr-class-flags-res2 (list (cons 'raw ehdr-class-flags-res2) (cons 'formatted (fmt-hex ehdr-class-flags-res2))))
        (cons 'ehdr-class-flags-user (list (cons 'raw ehdr-class-flags-user) (cons 'formatted (number->string ehdr-class-flags-user))))
        (cons 'ehdr-class-flags-res1 (list (cons 'raw ehdr-class-flags-res1) (cons 'formatted (fmt-hex ehdr-class-flags-res1))))
        (cons 'ehdr-class-flags-shm (list (cons 'raw ehdr-class-flags-shm) (cons 'formatted (number->string ehdr-class-flags-shm))))
        (cons 'ehdr-class-flags-sh (list (cons 'raw ehdr-class-flags-sh) (cons 'formatted (number->string ehdr-class-flags-sh))))
        (cons 'ehdr-class-flags (list (cons 'raw ehdr-class-flags) (cons 'formatted (fmt-hex ehdr-class-flags))))
        (cons 'meta-tag-type (list (cons 'raw meta-tag-type) (cons 'formatted (number->string meta-tag-type))))
        (cons 'meta-tag-len (list (cons 'raw meta-tag-len) (cons 'formatted (number->string meta-tag-len))))
        )))

    (catch (e)
      (err (str "ERF parse error: " e)))))

