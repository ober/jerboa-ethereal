        (cons 'comm-mode-min-st (list (cons 'raw comm-mode-min-st) (cons 'formatted (number->string comm-mode-min-st))))
        (cons 'comm-mode-queue-size (list (cons 'raw comm-mode-queue-size) (cons 'formatted (number->string comm-mode-queue-size))))
        (cons 'comm-mode-driver-version (list (cons 'raw comm-mode-driver-version) (cons 'formatted (fmt-hex comm-mode-driver-version))))
        (cons 'get-id-res (list (cons 'raw get-id-res) (cons 'formatted (fmt-hex get-id-res))))
        (cons 'get-id-length (list (cons 'raw get-id-length) (cons 'formatted (number->string get-id-length))))
        (cons 'get-id-id-string (list (cons 'raw get-id-id-string) (cons 'formatted (utf8->string get-id-id-string))))
