        (cons 'get-st-cur-res-pro-st-dbg (list (cons 'raw get-st-cur-res-pro-st-dbg) (cons 'formatted (if (= get-st-cur-res-pro-st-dbg 0) "Not set" "Set"))))
        (cons 'get-st-cur-res-pro-st-pgm (list (cons 'raw get-st-cur-res-pro-st-pgm) (cons 'formatted (if (= get-st-cur-res-pro-st-pgm 0) "Not set" "Set"))))
        (cons 'get-st-cur-res-pro-st-stim (list (cons 'raw get-st-cur-res-pro-st-stim) (cons 'formatted (if (= get-st-cur-res-pro-st-stim 0) "Not set" "Set"))))
        (cons 'get-st-cur-res-pro-st-daq (list (cons 'raw get-st-cur-res-pro-st-daq) (cons 'formatted (if (= get-st-cur-res-pro-st-daq 0) "Not set" "Set"))))
        (cons 'get-st-cur-res-pro-st-calpag (list (cons 'raw get-st-cur-res-pro-st-calpag) (cons 'formatted (if (= get-st-cur-res-pro-st-calpag 0) "Not set" "Set"))))
        (cons 'build-chksum-res3 (list (cons 'raw build-chksum-res3) (cons 'formatted (fmt-hex build-chksum-res3))))
        (cons 'build-chksum (list (cons 'raw build-chksum) (cons 'formatted (fmt-hex build-chksum))))
        (cons 'logical-data-page-number (list (cons 'raw logical-data-page-number) (cons 'formatted (fmt-hex logical-data-page-number))))
        (cons 'first-pid (list (cons 'raw first-pid) (cons 'formatted (fmt-hex first-pid))))
        (cons 'trigger-info (list (cons 'raw trigger-info) (cons 'formatted (fmt-hex trigger-info))))
        (cons 'payload-fmt (list (cons 'raw payload-fmt) (cons 'formatted (fmt-hex payload-fmt))))
        (cons 'payload-fmt-cluster-ident (list (cons 'raw payload-fmt-cluster-ident) (cons 'formatted (if (= payload-fmt-cluster-ident 0) "Not Present" "Present, when sent as response to TRIGGER_INITIATOR 2 or 3"))))
        (cons 'payload-timestamp-legacy (list (cons 'raw payload-timestamp-legacy) (cons 'formatted (fmt-hex payload-timestamp-legacy))))
        (cons 'daq-props (list (cons 'raw daq-props) (cons 'formatted (fmt-hex daq-props))))
        (cons 'daq-props-pid-off-supported (list (cons 'raw daq-props-pid-off-supported) (cons 'formatted (if (= daq-props-pid-off-supported 0) "Not set" "Set"))))
        (cons 'daq-props-timestamp-supported (list (cons 'raw daq-props-timestamp-supported) (cons 'formatted (if (= daq-props-timestamp-supported 0) "Not set" "Set"))))
        (cons 'daq-props-bit-stim-supported (list (cons 'raw daq-props-bit-stim-supported) (cons 'formatted (if (= daq-props-bit-stim-supported 0) "Not set" "Set"))))
        (cons 'daq-props-resume-supported (list (cons 'raw daq-props-resume-supported) (cons 'formatted (if (= daq-props-resume-supported 0) "Not set" "Set"))))
        (cons 'daq-props-prescaler-supported (list (cons 'raw daq-props-prescaler-supported) (cons 'formatted (if (= daq-props-prescaler-supported 0) "Not set" "Set"))))
        (cons 'daq-props-config-type (list (cons 'raw daq-props-config-type) (cons 'formatted (if (= daq-props-config-type 0) "Not set" "Set"))))
        (cons 'max-daq (list (cons 'raw max-daq) (cons 'formatted (number->string max-daq))))
        (cons 'max-event-channel (list (cons 'raw max-event-channel) (cons 'formatted (number->string max-event-channel))))
        (cons 'min-daq (list (cons 'raw min-daq) (cons 'formatted (number->string min-daq))))
        (cons 'daq-key-byte (list (cons 'raw daq-key-byte) (cons 'formatted (fmt-hex daq-key-byte))))
        (cons 'granularity-odt-entry-size-daq (list (cons 'raw granularity-odt-entry-size-daq) (cons 'formatted (number->string granularity-odt-entry-size-daq))))
        (cons 'max-odt-entry-size-daq (list (cons 'raw max-odt-entry-size-daq) (cons 'formatted (number->string max-odt-entry-size-daq))))
        (cons 'granularity-odt-entry-size-stim (list (cons 'raw granularity-odt-entry-size-stim) (cons 'formatted (number->string granularity-odt-entry-size-stim))))
        (cons 'max-odt-entry-size-stim (list (cons 'raw max-odt-entry-size-stim) (cons 'formatted (number->string max-odt-entry-size-stim))))
        (cons 'timestamp-mode (list (cons 'raw timestamp-mode) (cons 'formatted (number->string timestamp-mode))))
        (cons 'timestamp-mode-timestamp-fixed (list (cons 'raw timestamp-mode-timestamp-fixed) (cons 'formatted (if (= timestamp-mode-timestamp-fixed 0) "Not set" "Set"))))
        (cons 'timestamp-mode-timestamp-size (list (cons 'raw timestamp-mode-timestamp-size) (cons 'formatted (if (= timestamp-mode-timestamp-size 0) "Not set" "Set"))))
        (cons 'timestamp-ticks (list (cons 'raw timestamp-ticks) (cons 'formatted (number->string timestamp-ticks))))
        (cons 'daq-list-max-odt (list (cons 'raw daq-list-max-odt) (cons 'formatted (number->string daq-list-max-odt))))
        (cons 'daq-list-max-odt-entries (list (cons 'raw daq-list-max-odt-entries) (cons 'formatted (number->string daq-list-max-odt-entries))))
        (cons 'daq-list-fixed-event (list (cons 'raw daq-list-fixed-event) (cons 'formatted (number->string daq-list-fixed-event))))
        (cons 'daq-event-properties (list (cons 'raw daq-event-properties) (cons 'formatted (fmt-hex daq-event-properties))))
        (cons 'daq-event-properties-packed (list (cons 'raw daq-event-properties-packed) (cons 'formatted (if (= daq-event-properties-packed 0) "Not set" "Set"))))
        (cons 'daq-event-properties-stim (list (cons 'raw daq-event-properties-stim) (cons 'formatted (if (= daq-event-properties-stim 0) "Not set" "Set"))))
        (cons 'daq-event-properties-daq (list (cons 'raw daq-event-properties-daq) (cons 'formatted (if (= daq-event-properties-daq 0) "Not set" "Set"))))
        (cons 'max-daq-list (list (cons 'raw max-daq-list) (cons 'formatted (number->string max-daq-list))))
        (cons 'event-channel-name-length (list (cons 'raw event-channel-name-length) (cons 'formatted (number->string event-channel-name-length))))
        (cons 'event-channel-time-cycle (list (cons 'raw event-channel-time-cycle) (cons 'formatted (number->string event-channel-time-cycle))))
        (cons 'event-channel-priority (list (cons 'raw event-channel-priority) (cons 'formatted (number->string event-channel-priority))))
        (cons 'comm-mode-pgm (list (cons 'raw comm-mode-pgm) (cons 'formatted (fmt-hex comm-mode-pgm))))
        (cons 'comm-mode-pgm-slave-block-mode (list (cons 'raw comm-mode-pgm-slave-block-mode) (cons 'formatted (if (= comm-mode-pgm-slave-block-mode 0) "Not set" "Set"))))
        (cons 'comm-mode-pgm-interleaved-mode (list (cons 'raw comm-mode-pgm-interleaved-mode) (cons 'formatted (if (= comm-mode-pgm-interleaved-mode 0) "Not set" "Set"))))
        (cons 'comm-mode-pgm-master-block-mode (list (cons 'raw comm-mode-pgm-master-block-mode) (cons 'formatted (if (= comm-mode-pgm-master-block-mode 0) "Not set" "Set"))))
        (cons 'max-cto-pgm (list (cons 'raw max-cto-pgm) (cons 'formatted (number->string max-cto-pgm))))
        (cons 'max-bs-pgm (list (cons 'raw max-bs-pgm) (cons 'formatted (number->string max-bs-pgm))))
        (cons 'min-st-pgm (list (cons 'raw min-st-pgm) (cons 'formatted (number->string min-st-pgm))))
        (cons 'queue-size-pgm (list (cons 'raw queue-size-pgm) (cons 'formatted (number->string queue-size-pgm))))
        (cons 'reserved (list (cons 'raw reserved) (cons 'formatted (fmt-hex reserved))))
        (cons 'version-proto-major (list (cons 'raw version-proto-major) (cons 'formatted (number->string version-proto-major))))
        (cons 'version-proto-minor (list (cons 'raw version-proto-minor) (cons 'formatted (number->string version-proto-minor))))
        (cons 'version-transp-layer-major (list (cons 'raw version-transp-layer-major) (cons 'formatted (number->string version-transp-layer-major))))
        (cons 'version-transp-layer-minor (list (cons 'raw version-transp-layer-minor) (cons 'formatted (number->string version-transp-layer-minor))))
        (cons 'data-element-name (list (cons 'raw data-element-name) (cons 'formatted (utf8->string data-element-name))))
        (cons 'data-element-1byte (list (cons 'raw data-element-1byte) (cons 'formatted (fmt-hex data-element-1byte))))
        (cons 'data-element-2bytes (list (cons 'raw data-element-2bytes) (cons 'formatted (fmt-hex data-element-2bytes))))
        (cons 'data-element-4bytes (list (cons 'raw data-element-4bytes) (cons 'formatted (fmt-hex data-element-4bytes))))
        (cons 'unparsed (list (cons 'raw unparsed) (cons 'formatted (fmt-bytes unparsed))))
        )))

    (catch (e)
      (err (str "XCP parse error: " e)))))

