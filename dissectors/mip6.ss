           (opt-auth-auth-data (unwrap (slice buffer 6 1)))
           (vsm-data (unwrap (slice buffer 6 1)))
           (opt-badff-auth (unwrap (slice buffer 6 1)))
           (lra-u (unwrap (read-u8 buffer 8)))
           (lra-reserved (unwrap (read-u8 buffer 8)))
