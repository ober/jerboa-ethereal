        (cons 'opt-3gpp-charging-characteristic (list (cons 'raw opt-3gpp-charging-characteristic) (cons 'formatted (fmt-hex opt-3gpp-charging-characteristic))))
        (cons 'opt-3gpp-mei (list (cons 'raw opt-3gpp-mei) (cons 'formatted (utf8->string opt-3gpp-mei))))
        (cons 'opt-3gpp-msisdn (list (cons 'raw opt-3gpp-msisdn) (cons 'formatted (utf8->string opt-3gpp-msisdn))))
