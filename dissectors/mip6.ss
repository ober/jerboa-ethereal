           (opt-dmnp-dmnp-ipv6 (unwrap (slice buffer 2 16)))
           (nemo-mnp-pfl (unwrap (read-u8 buffer 3)))
           (nemo-mnp-mnp (unwrap (slice buffer 3 16)))
           (lmaa-reserved (unwrap (read-u8 buffer 3)))
           (lri-lifetime (unwrap (read-u16be buffer 4)))
           (opt-mnlli-lli (unwrap (slice buffer 4 1)))
           (opt-ipv4coa-addr (unwrap (read-u32be buffer 4)))
           (gre-key (unwrap (read-u32be buffer 4)))
           (opt-bi-status (unwrap (read-u8 buffer 4)))
           (bi-h-flag (unwrap (read-u8 buffer 4)))
           (bi-coa-ipv4 (unwrap (read-u32be buffer 4)))
