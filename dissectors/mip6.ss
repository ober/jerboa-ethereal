           (opt-mag-ipv6-address (unwrap (slice buffer 2 16)))
           (opt-acc-net-id-sub-opt-len (unwrap (read-u8 buffer 2)))
           (opt-acc-net-id-sub-opt-e-bit (unwrap (read-u8 buffer 2)))
           (opt-acc-net-id-sub-opt-net-name-len (unwrap (read-u8 buffer 2)))
