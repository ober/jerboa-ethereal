           (opt-ipv4coa-reserved (unwrap (read-u16be buffer 2)))
           (ipv4dra-reserved (unwrap (read-u16be buffer 2)))
           (opt-mhipv6ap-opt-code (unwrap (read-u8 buffer 2)))
           (opt-mhipv6ap-prefix-l (unwrap (read-u8 buffer 2)))
           (opt-mhipv6ap-ipv6-address (unwrap (slice buffer 2 16)))
           (opt-mhipv6ap-ipv6-address-prefix (unwrap (slice buffer 2 16)))
           (opt-bi-bid (unwrap (read-u16be buffer 2)))
           (ipv4ha-reserved (unwrap (read-u8 buffer 2)))
           (ipv4dsm-reserved (unwrap (read-u16be buffer 2)))
           (ipv4dsm-s-flag (unwrap (read-u8 buffer 2)))
           (cr-reserved (unwrap (read-u16be buffer 2)))
