        (cons 'opt-dmnp-reserved (list (cons 'raw opt-dmnp-reserved) (cons 'formatted (number->string opt-dmnp-reserved))))
        (cons 'opt-dmnp-prefix-len (list (cons 'raw opt-dmnp-prefix-len) (cons 'formatted (number->string opt-dmnp-prefix-len))))
        (cons 'opt-dmnp-dmnp-ipv4 (list (cons 'raw opt-dmnp-dmnp-ipv4) (cons 'formatted (fmt-ipv4 opt-dmnp-dmnp-ipv4))))
        (cons 'opt-dmnp-dmnp-ipv6 (list (cons 'raw opt-dmnp-dmnp-ipv6) (cons 'formatted (fmt-ipv6-address opt-dmnp-dmnp-ipv6))))
        (cons 'nemo-mnp-pfl (list (cons 'raw nemo-mnp-pfl) (cons 'formatted (number->string nemo-mnp-pfl))))
        (cons 'nemo-mnp-mnp (list (cons 'raw nemo-mnp-mnp) (cons 'formatted (fmt-ipv6-address nemo-mnp-mnp))))
        (cons 'lmaa-reserved (list (cons 'raw lmaa-reserved) (cons 'formatted (number->string lmaa-reserved))))
        (cons 'lri-lifetime (list (cons 'raw lri-lifetime) (cons 'formatted (fmt-hex lri-lifetime))))
        (cons 'opt-mnlli-lli (list (cons 'raw opt-mnlli-lli) (cons 'formatted (fmt-bytes opt-mnlli-lli))))
        (cons 'opt-ipv4coa-addr (list (cons 'raw opt-ipv4coa-addr) (cons 'formatted (fmt-ipv4 opt-ipv4coa-addr))))
        (cons 'gre-key (list (cons 'raw gre-key) (cons 'formatted (number->string gre-key))))
        (cons 'opt-bi-status (list (cons 'raw opt-bi-status) (cons 'formatted (number->string opt-bi-status))))
        (cons 'bi-h-flag (list (cons 'raw bi-h-flag) (cons 'formatted (number->string bi-h-flag))))
        (cons 'bi-coa-ipv4 (list (cons 'raw bi-coa-ipv4) (cons 'formatted (fmt-ipv4 bi-coa-ipv4))))
        (cons 'bi-coa-ipv6 (list (cons 'raw bi-coa-ipv6) (cons 'formatted (fmt-ipv6-address bi-coa-ipv6))))
        (cons 'ipv4dra-dra (list (cons 'raw ipv4dra-dra) (cons 'formatted (fmt-ipv4 ipv4dra-dra))))
        (cons 'cr-req-length (list (cons 'raw cr-req-length) (cons 'formatted (number->string cr-req-length))))
        (cons 'vsm-req-data (list (cons 'raw vsm-req-data) (cons 'formatted (fmt-bytes vsm-req-data))))
        (cons 'lmaa-ipv6 (list (cons 'raw lmaa-ipv6) (cons 'formatted (fmt-ipv6-address lmaa-ipv6))))
        (cons 'lmaa-ipv4 (list (cons 'raw lmaa-ipv4) (cons 'formatted (fmt-ipv4 lmaa-ipv4))))
        (cons 'opt-redir-addr-r2LMA-ipv6 (list (cons 'raw opt-redir-addr-r2LMA-ipv6) (cons 'formatted (fmt-ipv6-address opt-redir-addr-r2LMA-ipv6))))
        (cons 'opt-load-inf-sessions-in-use (list (cons 'raw opt-load-inf-sessions-in-use) (cons 'formatted (number->string opt-load-inf-sessions-in-use))))
        (cons 'lra-sequence (list (cons 'raw lra-sequence) (cons 'formatted (number->string lra-sequence))))
        (cons 'opt-auth-auth-data (list (cons 'raw opt-auth-auth-data) (cons 'formatted (fmt-bytes opt-auth-auth-data))))
        (cons 'vsm-data (list (cons 'raw vsm-data) (cons 'formatted (fmt-bytes vsm-data))))
        (cons 'opt-badff-auth (list (cons 'raw opt-badff-auth) (cons 'formatted (fmt-bytes opt-badff-auth))))
        (cons 'lra-u (list (cons 'raw lra-u) (cons 'formatted (if (= lra-u 0) "False" "True"))))
        (cons 'lra-reserved (list (cons 'raw lra-reserved) (cons 'formatted (fmt-hex lra-reserved))))
        (cons 'opt-load-inf-maximum-sessions (list (cons 'raw opt-load-inf-maximum-sessions) (cons 'formatted (number->string opt-load-inf-maximum-sessions))))
        (cons 'opt-acc-net-id-sub-opt-op-id (list (cons 'raw opt-acc-net-id-sub-opt-op-id) (cons 'formatted (fmt-bytes opt-acc-net-id-sub-opt-op-id))))
        (cons 'lra-lifetime (list (cons 'raw lra-lifetime) (cons 'formatted (fmt-hex lra-lifetime))))
        (cons 'opt-load-inf-used-capacity (list (cons 'raw opt-load-inf-used-capacity) (cons 'formatted (number->string opt-load-inf-used-capacity))))
        (cons 'opt-load-inf-maximum-capacity (list (cons 'raw opt-load-inf-maximum-capacity) (cons 'formatted (number->string opt-load-inf-maximum-capacity))))
        (cons 'opt-redir-addr-r2LMA-ipv4 (list (cons 'raw opt-redir-addr-r2LMA-ipv4) (cons 'formatted (fmt-ipv4 opt-redir-addr-r2LMA-ipv4))))
        )))

    (catch (e)
      (err (str "MIP6 parse error: " e)))))

;; dissect-mip6: parse MIP6 from bytevector
;; Returns (ok fields-alist) or (err message)