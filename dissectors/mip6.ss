        (cons 'lri-sequence (list (cons 'raw lri-sequence) (cons 'formatted (number->string lri-sequence))))
        (cons 'opt-3gpp-reserved (list (cons 'raw opt-3gpp-reserved) (cons 'formatted (number->string opt-3gpp-reserved))))
        (cons 'opt-3gpp-flag-m (list (cons 'raw opt-3gpp-flag-m) (cons 'formatted (number->string opt-3gpp-flag-m))))
        (cons 'opt-3gpp-pdn-gw-ipv4-addr (list (cons 'raw opt-3gpp-pdn-gw-ipv4-addr) (cons 'formatted (fmt-ipv4 opt-3gpp-pdn-gw-ipv4-addr))))
        (cons 'opt-3gpp-pdn-gw-ipv6-addr (list (cons 'raw opt-3gpp-pdn-gw-ipv6-addr) (cons 'formatted (fmt-ipv6-address opt-3gpp-pdn-gw-ipv6-addr))))
