        (cons 'ms-access-binary-number-of-bytes (list (cons 'raw ms-access-binary-number-of-bytes) (cons 'formatted (number->string ms-access-binary-number-of-bytes))))
        (cons 'ms-access-binary-local-pin-offset (list (cons 'raw ms-access-binary-local-pin-offset) (cons 'formatted (number->string ms-access-binary-local-pin-offset))))
        (cons 'ms-access-binary-local-pin-size (list (cons 'raw ms-access-binary-local-pin-size) (cons 'formatted (number->string ms-access-binary-local-pin-size))))
        (cons 'ms-access-binary-binary-data-offset (list (cons 'raw ms-access-binary-binary-data-offset) (cons 'formatted (number->string ms-access-binary-binary-data-offset))))
        (cons 'ms-access-binary-binary-data-size (list (cons 'raw ms-access-binary-binary-data-size) (cons 'formatted (number->string ms-access-binary-binary-data-size))))
        (cons 'ms-access-record-version (list (cons 'raw ms-access-record-version) (cons 'formatted (number->string ms-access-record-version))))
        (cons 'ms-access-record-app-id-offset (list (cons 'raw ms-access-record-app-id-offset) (cons 'formatted (number->string ms-access-record-app-id-offset))))
        (cons 'ms-access-record-app-id-size (list (cons 'raw ms-access-record-app-id-size) (cons 'formatted (number->string ms-access-record-app-id-size))))
        (cons 'ms-access-record-file-path-offset (list (cons 'raw ms-access-record-file-path-offset) (cons 'formatted (number->string ms-access-record-file-path-offset))))
        (cons 'ms-access-record-file-path-size (list (cons 'raw ms-access-record-file-path-size) (cons 'formatted (number->string ms-access-record-file-path-size))))
        (cons 'ms-access-record-record-number (list (cons 'raw ms-access-record-record-number) (cons 'formatted (number->string ms-access-record-record-number))))
        (cons 'ms-access-record-local-pin-offset (list (cons 'raw ms-access-record-local-pin-offset) (cons 'formatted (number->string ms-access-record-local-pin-offset))))
        (cons 'ms-access-record-local-pin-size (list (cons 'raw ms-access-record-local-pin-size) (cons 'formatted (number->string ms-access-record-local-pin-size))))
        (cons 'ms-access-record-record-data-offset (list (cons 'raw ms-access-record-record-data-offset) (cons 'formatted (number->string ms-access-record-record-data-offset))))
        (cons 'ms-access-record-record-data-size (list (cons 'raw ms-access-record-record-data-size) (cons 'formatted (number->string ms-access-record-record-data-size))))
        (cons 'nitz-year (list (cons 'raw nitz-year) (cons 'formatted (number->string nitz-year))))
        (cons 'nitz-month (list (cons 'raw nitz-month) (cons 'formatted (number->string nitz-month))))
        (cons 'nitz-day (list (cons 'raw nitz-day) (cons 'formatted (number->string nitz-day))))
        (cons 'nitz-hour (list (cons 'raw nitz-hour) (cons 'formatted (number->string nitz-hour))))
        (cons 'nitz-minute (list (cons 'raw nitz-minute) (cons 'formatted (number->string nitz-minute))))
        (cons 'nitz-second (list (cons 'raw nitz-second) (cons 'formatted (number->string nitz-second))))
        (cons 'nitz-timezone-offset-minutes (list (cons 'raw nitz-timezone-offset-minutes) (cons 'formatted (number->string nitz-timezone-offset-minutes))))
        (cons 'nitz-daylight-saving-time-offset-minutes (list (cons 'raw nitz-daylight-saving-time-offset-minutes) (cons 'formatted (number->string nitz-daylight-saving-time-offset-minutes))))
        (cons 'nitz-data-class (list (cons 'raw nitz-data-class) (cons 'formatted (fmt-hex nitz-data-class))))
        (cons 'data-class-gprs (list (cons 'raw data-class-gprs) (cons 'formatted (if (= data-class-gprs 0) "Not set" "Set"))))
        (cons 'data-class-edge (list (cons 'raw data-class-edge) (cons 'formatted (if (= data-class-edge 0) "Not set" "Set"))))
        (cons 'data-class-umts (list (cons 'raw data-class-umts) (cons 'formatted (if (= data-class-umts 0) "Not set" "Set"))))
        (cons 'data-class-hsdpa (list (cons 'raw data-class-hsdpa) (cons 'formatted (if (= data-class-hsdpa 0) "Not set" "Set"))))
        (cons 'data-class-hsupa (list (cons 'raw data-class-hsupa) (cons 'formatted (if (= data-class-hsupa 0) "Not set" "Set"))))
        (cons 'data-class-lte (list (cons 'raw data-class-lte) (cons 'formatted (if (= data-class-lte 0) "Not set" "Set"))))
        (cons 'data-class-5g (list (cons 'raw data-class-5g) (cons 'formatted (if (= data-class-5g 0) "Not set" "Set"))))
        (cons 'data-class-reserved-gsm (list (cons 'raw data-class-reserved-gsm) (cons 'formatted (if (= data-class-reserved-gsm 0) "Not set" "Set"))))
        (cons 'data-class-1xrtt (list (cons 'raw data-class-1xrtt) (cons 'formatted (if (= data-class-1xrtt 0) "Not set" "Set"))))
        (cons 'data-class-1xevdo (list (cons 'raw data-class-1xevdo) (cons 'formatted (if (= data-class-1xevdo 0) "Not set" "Set"))))
        (cons 'data-class-1xevdoreva (list (cons 'raw data-class-1xevdoreva) (cons 'formatted (if (= data-class-1xevdoreva 0) "Not set" "Set"))))
        (cons 'data-class-1xevdv (list (cons 'raw data-class-1xevdv) (cons 'formatted (if (= data-class-1xevdv 0) "Not set" "Set"))))
        (cons 'data-class-3xrtt (list (cons 'raw data-class-3xrtt) (cons 'formatted (if (= data-class-3xrtt 0) "Not set" "Set"))))
        (cons 'data-class-1xevdorevb (list (cons 'raw data-class-1xevdorevb) (cons 'formatted (if (= data-class-1xevdorevb 0) "Not set" "Set"))))
        (cons 'data-class-umb (list (cons 'raw data-class-umb) (cons 'formatted (if (= data-class-umb 0) "Not set" "Set"))))
        (cons 'data-class-reserved-cdma (list (cons 'raw data-class-reserved-cdma) (cons 'formatted (if (= data-class-reserved-cdma 0) "Not set" "Set"))))
        (cons 'data-class-custom (list (cons 'raw data-class-custom) (cons 'formatted (if (= data-class-custom 0) "Not set" "Set"))))
        )))

    (catch (e)
      (err (str "MBIM parse error: " e)))))

