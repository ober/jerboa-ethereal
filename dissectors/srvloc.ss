        (cons 'attrreq-slpspi (list (cons 'raw attrreq-slpspi) (cons 'formatted (utf8->string attrreq-slpspi))))
        (cons 'attrrply-attrlistlen (list (cons 'raw attrrply-attrlistlen) (cons 'formatted (number->string attrrply-attrlistlen))))
        (cons 'attrrply-attrauthcount (list (cons 'raw attrrply-attrauthcount) (cons 'formatted (number->string attrrply-attrauthcount))))
        (cons 'daadvert-urllen (list (cons 'raw daadvert-urllen) (cons 'formatted (number->string daadvert-urllen))))
