        (cons 'srvtypereq-nameauthlistlenall (list (cons 'raw srvtypereq-nameauthlistlenall) (cons 'formatted (number->string srvtypereq-nameauthlistlenall))))
        (cons 'srvtypereq-nameauthlistlen (list (cons 'raw srvtypereq-nameauthlistlen) (cons 'formatted (number->string srvtypereq-nameauthlistlen))))
