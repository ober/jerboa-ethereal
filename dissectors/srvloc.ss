        (cons 'daadvert-scopelistlen (list (cons 'raw daadvert-scopelistlen) (cons 'formatted (number->string daadvert-scopelistlen))))
        (cons 'daadvert-scopelist (list (cons 'raw daadvert-scopelist) (cons 'formatted (utf8->string daadvert-scopelist))))
        (cons 'daadvert-attrlistlen (list (cons 'raw daadvert-attrlistlen) (cons 'formatted (number->string daadvert-attrlistlen))))
        (cons 'daadvert-attrlist (list (cons 'raw daadvert-attrlist) (cons 'formatted (utf8->string daadvert-attrlist))))
        (cons 'daadvert-slpspilen (list (cons 'raw daadvert-slpspilen) (cons 'formatted (number->string daadvert-slpspilen))))
        (cons 'daadvert-slpspi (list (cons 'raw daadvert-slpspi) (cons 'formatted (utf8->string daadvert-slpspi))))
        (cons 'daadvert-authcount (list (cons 'raw daadvert-authcount) (cons 'formatted (number->string daadvert-authcount))))
        (cons 'srvtypereq-prlistlen (list (cons 'raw srvtypereq-prlistlen) (cons 'formatted (number->string srvtypereq-prlistlen))))
