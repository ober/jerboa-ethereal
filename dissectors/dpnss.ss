;;
;; AI Generated by google:
;; DPNSS (Digital Private Network Signalling System) is a telephony network protocol for linking
;; Private Automatic Branch Exchanges (PBXs) over digital trunk lines, allowing shared advanced calling features
;; (like Call Forward, Caller ID, Call Transfer) across multiple sites as if on one system. Developed from BT's DASS,
;; it uses a separate data channel (D-channel, often Time Slot 16 on E1 links) for signaling,
;; enabling seamless voice services across different manufacturers' equipment within a private network.
;;
;; Key Aspects of DPNSS
;; Purpose: Extends single-PBX features (like extensions, voicemail integration) across interconnected PBXs in a private network.
;; Origin: Defined by British Telecom (BT) for private network interoperability.
;; Technology: Operates over digital circuits (like E1/T1) using ISDN interfaces, reserving specific time slots for signaling.
;; Interoperability: Allows equipment from different vendors (e.g., Mitel, Meridian) to communicate advanced services.
;; Services Supported: Includes call forwarding, caller ID, message waiting indication (MWI), and call transfer.
;; Standards: Defined in documents like BTNR188 and RFC 4129 for extensions.
;; How it Works
;; Signaling Channel: Uses a dedicated data channel (D-channel) within the digital link for control messages, separate from voice channels (B-channels).
;; Feature Negotiation: PBXs use the DPNSS protocol to signal and offer supplementary services to each other.
;; Network Configuration: Administrators set up trunk groups and routing to connect PBXs, creating a unified network.
;; DPNSS vs. QSIG
;; DPNSS is a private network protocol, while QSIG (Signalling System No. 7 based) is a more formal standard for public and private networks.
;; Gateways are often used to connect DPNSS networks to QSIG networks, with basic calls typically passing through, as shown in this Mitel documentation.
;;

;; jerboa-ethereal/dissectors/dpnss.ss
;; Auto-generated from wireshark/epan/dissectors/packet-dpnss.c
;; RFC 4129

(import (jerboa prelude))

;; ── Protocol Helpers ─────────────────────────────────────────────────
(def (read-u8 buf offset)
  (if (>= offset (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u8-ref buf offset))))

(def (read-u16be buf offset)
  (if (> (+ offset 2) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u16-ref buf offset (endianness big)))))

(def (read-u24be buf offset)
  (if (> (+ offset 3) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (+ (* (bytevector-u8-ref buf offset) 65536)
             (* (bytevector-u8-ref buf (+ offset 1)) 256)
             (bytevector-u8-ref buf (+ offset 2))))))

(def (read-u32be buf offset)
  (if (> (+ offset 4) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u32-ref buf offset (endianness big)))))

(def (read-u16le buf offset)
  (if (> (+ offset 2) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u16-ref buf offset (endianness little)))))

(def (read-u32le buf offset)
  (if (> (+ offset 4) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u32-ref buf offset (endianness little)))))

(def (read-u64be buf offset)
  (if (> (+ offset 8) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u64-ref buf offset (endianness big)))))

(def (read-u64le buf offset)
  (if (> (+ offset 8) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u64-ref buf offset (endianness little)))))

(def (slice buf offset len)
  (if (> (+ offset len) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (let ((result (make-bytevector len)))
            (bytevector-copy! buf offset result 0 len)
            result))))

(def (extract-bits val mask shift)
  (bitwise-arithmetic-shift-right (bitwise-and val mask) shift))

(def (fmt-ipv4 addr)
  (let ((b0 (bitwise-arithmetic-shift-right addr 24))
        (b1 (bitwise-and (bitwise-arithmetic-shift-right addr 16) 255))
        (b2 (bitwise-and (bitwise-arithmetic-shift-right addr 8) 255))
        (b3 (bitwise-and addr 255)))
    (str b0 "." b1 "." b2 "." b3)))

(def (fmt-mac bytes)
  (string-join
    (map (lambda (b) (string-pad (number->string b 16) 2 #\0))
         (bytevector->list bytes))
    ":"))

(def (fmt-hex val)
  (str "0x" (number->string val 16)))

(def (fmt-oct val)
  (str "0" (number->string val 8)))

(def (fmt-port port)
  (number->string port))

(def (fmt-bytes bv)
  (string-join
    (map (lambda (b) (string-pad (number->string b 16) 2 #\0))
         (bytevector->list bv))
    " "))

(def (fmt-ipv6-address bytes)
  (let loop ((i 0) (parts '()))
    (if (>= i 16)
        (string-join (reverse parts) ":")
        (loop (+ i 2)
              (cons (let ((w (+ (* (bytevector-u8-ref bytes i) 256)
                                (bytevector-u8-ref bytes (+ i 1)))))
                      (number->string w 16))
                    parts)))))

;; ── Dissector ──────────────────────────────────────────────────────
(def (dissect-dpnss buffer)
  "Digital Private Signalling System No 1"
  (try
    (let* (
           (ext-bit-notall (unwrap (read-u8 buffer 0)))
           (sic-oct2-net-ind-clk (unwrap (read-u8 buffer 0)))
           (sic-oct2-sync-data-format (unwrap (read-u8 buffer 0)))
           (sic-oct2-sync-byte-timing (unwrap (read-u8 buffer 0)))
           (sic-oct2-async-flow-ctrl (unwrap (read-u8 buffer 0)))
           (sic-oct2-duplex (unwrap (read-u8 buffer 0)))
           (sup-str (unwrap (slice buffer 0 1)))
           (dest-addr (unwrap (slice buffer 0 1)))
           (indication-field (unwrap (slice buffer 0 1)))
           (selection-field (unwrap (slice buffer 0 1)))
           (subcode (unwrap (read-u8 buffer 0)))
           (user-information (unwrap (slice buffer 0 1)))
           (ext-bit (unwrap (read-u8 buffer 1)))
           )

      (ok (list
        (cons 'ext-bit-notall (list (cons 'raw ext-bit-notall) (cons 'formatted (if (= ext-bit-notall 0) "Invalid" "no further octets"))))
        (cons 'sic-oct2-net-ind-clk (list (cons 'raw sic-oct2-net-ind-clk) (cons 'formatted (if (= sic-oct2-net-ind-clk 0) "Clock Locked to Transmission" "Bits E4/E5/E6 indicate phase"))))
        (cons 'sic-oct2-sync-data-format (list (cons 'raw sic-oct2-sync-data-format) (cons 'formatted (if (= sic-oct2-sync-data-format 0) "Anonymous or Unformatted" "X.25 Packet Mode"))))
        (cons 'sic-oct2-sync-byte-timing (list (cons 'raw sic-oct2-sync-byte-timing) (cons 'formatted (if (= sic-oct2-sync-byte-timing 0) "Not Provided" "Provided"))))
        (cons 'sic-oct2-async-flow-ctrl (list (cons 'raw sic-oct2-async-flow-ctrl) (cons 'formatted (if (= sic-oct2-async-flow-ctrl 0) "TA does not have ESRA capability" "TA has ESRA capability"))))
        (cons 'sic-oct2-duplex (list (cons 'raw sic-oct2-duplex) (cons 'formatted (if (= sic-oct2-duplex 0) "Full Duplex (FDX)" "Half Duplex (HDX)"))))
        (cons 'sup-str (list (cons 'raw sup-str) (cons 'formatted (utf8->string sup-str))))
        (cons 'dest-addr (list (cons 'raw dest-addr) (cons 'formatted (utf8->string dest-addr))))
        (cons 'indication-field (list (cons 'raw indication-field) (cons 'formatted (utf8->string indication-field))))
        (cons 'selection-field (list (cons 'raw selection-field) (cons 'formatted (utf8->string selection-field))))
        (cons 'subcode (list (cons 'raw subcode) (cons 'formatted (number->string subcode))))
        (cons 'user-information (list (cons 'raw user-information) (cons 'formatted (fmt-bytes user-information))))
        (cons 'ext-bit (list (cons 'raw ext-bit) (cons 'formatted (if (= ext-bit 0) "no further octets" "further octet(s) follow"))))
        )))

    (catch (e)
      (err (str "DPNSS parse error: " e)))))

;; dissect-dpnss: parse DPNSS from bytevector
;; Returns (ok fields-alist) or (err message)