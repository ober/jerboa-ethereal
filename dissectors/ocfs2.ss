        (cons 'lock-flag-nodlckwt (list (cons 'raw lock-flag-nodlckwt) (cons 'formatted (if (= lock-flag-nodlckwt 0) "Not set" "Set"))))
        (cons 'lock-flag-unlock (list (cons 'raw lock-flag-unlock) (cons 'formatted (if (= lock-flag-unlock 0) "Not set" "Set"))))
        (cons 'lock-flag-cancel (list (cons 'raw lock-flag-cancel) (cons 'formatted (if (= lock-flag-cancel 0) "Not set" "Set"))))
        (cons 'lock-flag-deqall (list (cons 'raw lock-flag-deqall) (cons 'formatted (if (= lock-flag-deqall 0) "Not set" "Set"))))
