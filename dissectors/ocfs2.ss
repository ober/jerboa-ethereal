           (lock-flag-xid-conflict (extract-bits lock-flags 0x400000 22))
           (lock-flag-force (extract-bits lock-flags 0x800000 23))
           (lock-flag-revvalblk (extract-bits lock-flags 0x1000000 24))
           (lock-flag-unused2 (extract-bits lock-flags 0xE000000 25))
           (lock-flag-migration (extract-bits lock-flags 0x10000000 28))
           (lock-flag-put-lvb (extract-bits lock-flags 0x20000000 29))
           (lock-flag-get-lvb (extract-bits lock-flags 0x40000000 30))
           (lock-flag-recovery (extract-bits lock-flags 0x80000000 31))
           (data-len (unwrap (read-u16be buffer 2)))
           (mres-num-locks (unwrap (read-u8 buffer 2)))
           (mres-flags (unwrap (read-u8 buffer 3)))
           (mres-flag-recovery (extract-bits mres-flags 0x2 1))
           (mres-flag-migration (extract-bits mres-flags 0x4 2))
           (mres-flag-all-done (extract-bits mres-flags 0xF8 3))
           (pad (unwrap (read-u16be buffer 4)))
           (mres-total-locks (unwrap (read-u32be buffer 4)))
           (sys-status (unwrap (read-u32be buffer 8)))
           (name (unwrap (slice buffer 8 32)))
           (status (unwrap (read-u32be buffer 12)))
           (key (unwrap (read-u32be buffer 16)))
           (msg-num (unwrap (read-u32be buffer 20)))
           (node-idx (unwrap (read-u8 buffer 24)))
           (payload (unwrap (slice buffer 24 1)))
           (mres-ml-flags (unwrap (read-u8 buffer 106)))
           (mres-convert-type (unwrap (read-u8 buffer 108)))
           (mres-highest-blocked (unwrap (read-u8 buffer 109)))
           (mres-node (unwrap (read-u8 buffer 110)))
           (node-map (unwrap (slice buffer 183 1)))
           (qr-node (unwrap (read-u8 buffer 183)))
           (qr-numregions (unwrap (read-u8 buffer 184)))
           (qr-namelen (unwrap (read-u8 buffer 185)))
           (qr-domain (unwrap (slice buffer 187 64)))
           (qr-region (unwrap (slice buffer 251 1)))
           (qn-nodenum (unwrap (read-u8 buffer 251)))
           (qn-numnodes (unwrap (read-u8 buffer 252)))
           (qn-namelen (unwrap (read-u8 buffer 253)))
           (qn-domain (unwrap (slice buffer 254 64)))
           (qn-node (unwrap (read-u8 buffer 318)))
           (qn-port (unwrap (read-u16be buffer 320)))
           (qn-ip (unwrap (read-u32be buffer 322)))
           (flags (unwrap (read-u32be buffer 330)))
           (lvb1 (unwrap (slice buffer 474 24)))
           (lvb2 (unwrap (slice buffer 498 24)))
           (lvb3 (unwrap (slice buffer 522 16)))
           (master (unwrap (read-u8 buffer 546)))
           (new-master (unwrap (read-u8 buffer 547)))
           (domain-name-len (unwrap (read-u8 buffer 557)))
           (domain-name (unwrap (slice buffer 558 64)))
           (namelen (unwrap (read-u8 buffer 625)))
           (pad16 (unwrap (read-u16be buffer 632)))
           (reco-lvb (unwrap (slice buffer 638 64)))
           (dead-node (unwrap (read-u8 buffer 703)))
           (pad8 (unwrap (read-u8 buffer 705)))
           (pad32 (unwrap (read-u32be buffer 706)))
           )

      (ok (list
        (cons 'lock-flags (list (cons 'raw lock-flags) (cons 'formatted (fmt-hex lock-flags))))
        (cons 'lock-flag-unused1 (list (cons 'raw lock-flag-unused1) (cons 'formatted (if (= lock-flag-unused1 0) "Not set" "Set"))))
        (cons 'lock-flag-orphan (list (cons 'raw lock-flag-orphan) (cons 'formatted (if (= lock-flag-orphan 0) "Not set" "Set"))))
