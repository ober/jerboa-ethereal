        (cons 'header-tunnel-durable (list (cons 'raw header-tunnel-durable) (cons 'formatted (number->string header-tunnel-durable))))
        (cons 'header-tunnel-broadcast (list (cons 'raw header-tunnel-broadcast) (cons 'formatted (number->string header-tunnel-broadcast))))
        )))

    (catch (e)
      (err (str "AMQP parse error: " e)))))

;; dissect-amqp: parse AMQP from bytevector
;; Returns (ok fields-alist) or (err message)