        (cons 'passthrough-data-length (list (cons 'raw passthrough-data-length) (cons 'formatted (fmt-hex passthrough-data-length))))
        (cons 'number-of-settings (list (cons 'raw number-of-settings) (cons 'formatted (number->string number-of-settings))))
        (cons 'settings-value (list (cons 'raw settings-value) (cons 'formatted (fmt-hex settings-value))))
        (cons 'unit-unknown (list (cons 'raw unit-unknown) (cons 'formatted (fmt-hex unit-unknown))))
        (cons 'unit-id (list (cons 'raw unit-id) (cons 'formatted (fmt-hex unit-id))))
        (cons 'passthrough-company-id (list (cons 'raw passthrough-company-id) (cons 'formatted (number->string passthrough-company-id))))
        (cons 'absolute-volume-rfa (list (cons 'raw absolute-volume-rfa) (cons 'formatted (fmt-hex absolute-volume-rfa))))
        (cons 'absolute-volume (list (cons 'raw absolute-volume) (cons 'formatted (fmt-hex absolute-volume))))
        (cons 'subunit-extension-code (list (cons 'raw subunit-extension-code) (cons 'formatted (fmt-hex subunit-extension-code))))
        (cons 'pdu-id (list (cons 'raw pdu-id) (cons 'formatted (fmt-hex pdu-id))))
        (cons 'rfa (list (cons 'raw rfa) (cons 'formatted (fmt-hex rfa))))
        (cons 'length (list (cons 'raw length) (cons 'formatted (number->string length))))
        (cons 'player-id (list (cons 'raw player-id) (cons 'formatted (number->string player-id))))
        (cons 'folder-depth (list (cons 'raw folder-depth) (cons 'formatted (number->string folder-depth))))
        (cons 'folder-name-length (list (cons 'raw folder-name-length) (cons 'formatted (number->string folder-name-length))))
        (cons 'folder-name (list (cons 'raw folder-name) (cons 'formatted (utf8->string folder-name))))
        (cons 'start-item (list (cons 'raw start-item) (cons 'formatted (number->string start-item))))
        (cons 'end-item (list (cons 'raw end-item) (cons 'formatted (number->string end-item))))
        (cons 'number-of-items16 (list (cons 'raw number-of-items16) (cons 'formatted (number->string number-of-items16))))
        (cons 'uid (list (cons 'raw uid) (cons 'formatted (fmt-hex uid))))
        (cons 'search-length (list (cons 'raw search-length) (cons 'formatted (number->string search-length))))
        (cons 'uid-counter (list (cons 'raw uid-counter) (cons 'formatted (fmt-hex uid-counter))))
        (cons 'number-of-items (list (cons 'raw number-of-items) (cons 'formatted (number->string number-of-items))))
        )))

    (catch (e)
      (err (str "BTAVRCP parse error: " e)))))

;; dissect-btavrcp: parse BTAVRCP from bytevector
;; Returns (ok fields-alist) or (err message)