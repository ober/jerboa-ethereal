           (ambr-data (unwrap (slice buffer 0 1)))
           (ipv6-interface-identifier (unwrap (slice buffer 0 8)))
           (3gpp-pdnid (unwrap (read-u8 buffer 0)))
           (bpdu-flags (unwrap (read-u8 buffer 0)))
           (bpdu-fcs-present (extract-bits bpdu-flags 0x0 0))
           (bpdu-zeropad (extract-bits bpdu-flags 0x0 0))
           (bpdu-bcontrol (extract-bits bpdu-flags 0x0 0))
           (bpdu-pads (extract-bits bpdu-flags 0x0 0))
           (bpdu-pad (unwrap (slice buffer 0 1)))
           (flags (unwrap (read-u8 buffer 0)))
           (flags-pid (extract-bits flags 0x80 7))
           (flags-field-length (extract-bits flags 0x40 6))
           (sub-frame-length (unwrap (read-u16be buffer 0)))
           (crtp-ip-id (unwrap (read-u16be buffer 0)))
           (crtp-fh-flags (unwrap (read-u8 buffer 1)))
           (crtp-fh-cidlenflag (extract-bits crtp-fh-flags 0x0 0))
           (crtp-fh-dataflag (extract-bits crtp-fh-flags 0x0 0))
           (control (unwrap (read-u8 buffer 1)))
           (sequence-num (unwrap (read-u24be buffer 1)))
           (crtp-cs-cnt (unwrap (read-u8 buffer 1)))
           (identifier (unwrap (read-u8 buffer 1)))
           (crtp-seq (unwrap (read-u8 buffer 2)))
           (crtp-gen (unwrap (read-u8 buffer 2)))
           (length (unwrap (read-u16be buffer 2)))
           (opt-id (unwrap (slice buffer 2 1)))
           (opt-data (unwrap (slice buffer 2 1)))
           (opt-class (unwrap (read-u8 buffer 2)))
           (opt-prefix (unwrap (slice buffer 2 1)))
           (sub-option-length (unwrap (read-u8 buffer 2)))
           (unique-digit (unwrap (read-u8 buffer 2)))
