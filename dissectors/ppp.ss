           (ncp-tinygram-comp (unwrap (read-u8 buffer 0)))
           (ncp-mac (unwrap (slice buffer 0 6)))
           (ncp-mac-l (unwrap (slice buffer 0 6)))
           (ncp-mac-m (unwrap (slice buffer 0 6)))
           (ncp-ieee-802-tagged-frame (unwrap (read-u8 buffer 0)))
           (opt-alignment (unwrap (read-u8 buffer 0)))
           (opt-oui (unwrap (read-u24be buffer 0)))
           (opt-subtype (unwrap (read-u8 buffer 0)))
           (opt-history-count (unwrap (read-u16be buffer 0)))
           (opt-cm (unwrap (read-u8 buffer 0)))
           (opt-cm-reserved (extract-bits opt-cm 0xF8 3))
           (opt-supported-bits (unwrap (read-u32be buffer 0)))
           (opt-supported-bits-h (extract-bits opt-supported-bits 0x0 0))
           (opt-supported-bits-m (extract-bits opt-supported-bits 0x0 0))
           (opt-supported-bits-s (extract-bits opt-supported-bits 0x0 0))
