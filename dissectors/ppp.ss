;; jerboa-ethereal/dissectors/ppp.ss
;; Auto-generated from wireshark/epan/dissectors/packet-ppp.c
;; RFC 1661

(import (jerboa prelude))

;; ── Protocol Helpers ─────────────────────────────────────────────────
(def (read-u8 buf offset)
  (if (>= offset (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u8-ref buf offset))))

(def (read-u16be buf offset)
  (if (> (+ offset 2) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u16-ref buf offset (endianness big)))))

(def (read-u24be buf offset)
  (if (> (+ offset 3) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (+ (* (bytevector-u8-ref buf offset) 65536)
             (* (bytevector-u8-ref buf (+ offset 1)) 256)
             (bytevector-u8-ref buf (+ offset 2))))))

(def (read-u32be buf offset)
  (if (> (+ offset 4) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u32-ref buf offset (endianness big)))))

(def (read-u16le buf offset)
  (if (> (+ offset 2) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u16-ref buf offset (endianness little)))))

(def (read-u32le buf offset)
  (if (> (+ offset 4) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u32-ref buf offset (endianness little)))))

(def (read-u64be buf offset)
  (if (> (+ offset 8) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u64-ref buf offset (endianness big)))))

(def (read-u64le buf offset)
  (if (> (+ offset 8) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (bytevector-u64-ref buf offset (endianness little)))))

(def (slice buf offset len)
  (if (> (+ offset len) (bytevector-length buf))
      (err "Buffer overrun")
      (ok (let ((result (make-bytevector len)))
            (bytevector-copy! buf offset result 0 len)
            result))))

(def (extract-bits val mask shift)
  (bitwise-arithmetic-shift-right (bitwise-and val mask) shift))

(def (fmt-ipv4 addr)
  (let ((b0 (bitwise-arithmetic-shift-right addr 24))
        (b1 (bitwise-and (bitwise-arithmetic-shift-right addr 16) 255))
        (b2 (bitwise-and (bitwise-arithmetic-shift-right addr 8) 255))
        (b3 (bitwise-and addr 255)))
    (str b0 "." b1 "." b2 "." b3)))

(def (fmt-mac bytes)
  (string-join
    (map (lambda (b) (string-pad (number->string b 16) 2 #\0))
         (bytevector->list bytes))
    ":"))

(def (fmt-hex val)
  (str "0x" (number->string val 16)))

(def (fmt-oct val)
  (str "0" (number->string val 8)))

(def (fmt-port port)
  (number->string port))

(def (fmt-bytes bv)
  (string-join
    (map (lambda (b) (string-pad (number->string b 16) 2 #\0))
         (bytevector->list bv))
    " "))

(def (fmt-ipv6-address bytes)
  (let loop ((i 0) (parts '()))
    (if (>= i 16)
        (string-join (reverse parts) ":")
        (loop (+ i 2)
              (cons (let ((w (+ (* (bytevector-u8-ref bytes i) 256)
                                (bytevector-u8-ref bytes (+ i 1)))))
                      (number->string w 16))
                    parts)))))

;; ── Dissector ──────────────────────────────────────────────────────
(def (dissect-ppp buffer)
  "PPP In HDLC-Like Framing"
  (try
    (let* (
           (frag (unwrap (read-u8 buffer 0)))
           (sequence-num-cls (extract-bits frag 0x0 0))
           (sequence-num-reserved (extract-bits frag 0x0 0))
           (frag-short (unwrap (read-u8 buffer 0)))
           (frag-first (extract-bits frag-short 0x0 0))
           (frag-last (extract-bits frag-short 0x0 0))
           (short-sequence-num-cls (extract-bits frag-short 0x0 0))
           (short-sequence-num (unwrap (read-u16be buffer 0)))
           (crtp-cid8 (unwrap (read-u8 buffer 0)))
           (crtp-cid16 (unwrap (read-u16be buffer 0)))
           (code (unwrap (read-u8 buffer 0)))
           (opt-kind (unwrap (read-u8 buffer 0)))
           (opt-mru (unwrap (read-u16be buffer 0)))
           (opt-asyncmap (unwrap (read-u32be buffer 0)))
           (opt-asyncmap-us (extract-bits opt-asyncmap 0x80000000 31))
           (opt-asyncmap-rs (extract-bits opt-asyncmap 0x40000000 30))
           (opt-asyncmap-gs (extract-bits opt-asyncmap 0x20000000 29))
           (opt-asyncmap-fs (extract-bits opt-asyncmap 0x10000000 28))
           (opt-asyncmap-esc (extract-bits opt-asyncmap 0x8000000 27))
           (opt-asyncmap-sub (extract-bits opt-asyncmap 0x4000000 26))
           (opt-asyncmap-em (extract-bits opt-asyncmap 0x2000000 25))
           (opt-asyncmap-can (extract-bits opt-asyncmap 0x1000000 24))
           (opt-asyncmap-etb (extract-bits opt-asyncmap 0x800000 23))
           (opt-asyncmap-syn (extract-bits opt-asyncmap 0x400000 22))
           (opt-asyncmap-nak (extract-bits opt-asyncmap 0x200000 21))
           (opt-asyncmap-dc4 (extract-bits opt-asyncmap 0x100000 20))
           (opt-asyncmap-dc3 (extract-bits opt-asyncmap 0x80000 19))
           (opt-asyncmap-dc2 (extract-bits opt-asyncmap 0x40000 18))
           (opt-asyncmap-dc1 (extract-bits opt-asyncmap 0x20000 17))
           (opt-asyncmap-dle (extract-bits opt-asyncmap 0x10000 16))
           (opt-asyncmap-si (extract-bits opt-asyncmap 0x8000 15))
           (opt-asyncmap-so (extract-bits opt-asyncmap 0x4000 14))
           (opt-asyncmap-cr (extract-bits opt-asyncmap 0x2000 13))
           (opt-asyncmap-ff (extract-bits opt-asyncmap 0x1000 12))
           (opt-asyncmap-vt (extract-bits opt-asyncmap 0x800 11))
           (opt-asyncmap-lf (extract-bits opt-asyncmap 0x400 10))
           (opt-asyncmap-ht (extract-bits opt-asyncmap 0x200 9))
           (opt-asyncmap-bs (extract-bits opt-asyncmap 0x100 8))
           (opt-asyncmap-bel (extract-bits opt-asyncmap 0x80 7))
           (opt-asyncmap-ack (extract-bits opt-asyncmap 0x40 6))
           (opt-asyncmap-enq (extract-bits opt-asyncmap 0x20 5))
           (opt-asyncmap-eot (extract-bits opt-asyncmap 0x10 4))
           (opt-asyncmap-etx (extract-bits opt-asyncmap 0x8 3))
           (opt-asyncmap-stx (extract-bits opt-asyncmap 0x4 2))
           (opt-asyncmap-soh (extract-bits opt-asyncmap 0x2 1))
           (opt-asyncmap-nul (extract-bits opt-asyncmap 0x1 0))
           (opt-fcs-alternatives (unwrap (read-u8 buffer 0)))
           (opt-fcs-alternatives-ccitt32 (extract-bits opt-fcs-alternatives 0x4 2))
           (opt-fcs-alternatives-ccitt16 (extract-bits opt-fcs-alternatives 0x2 1))
           (opt-fcs-alternatives-null (extract-bits opt-fcs-alternatives 0x1 0))
           (opt-hdlc-address (unwrap (slice buffer 0 1)))
           (opt-message (unwrap (slice buffer 0 1)))
           (opt-unused (unwrap (slice buffer 0 2)))
           (opt-link-discrim (unwrap (read-u16be buffer 0)))
           (opt-cobs-flags (unwrap (read-u8 buffer 0)))
           (opt-cobs-flags-res (extract-bits opt-cobs-flags 0xFC 2))
           (opt-cobs-flags-pre (extract-bits opt-cobs-flags 0x2 1))
           (opt-cobs-flags-zxe (extract-bits opt-cobs-flags 0x1 0))
           (opt-max-susp-classes (unwrap (read-u8 buffer 0)))
           (opt-language-tag (unwrap (slice buffer 0 1)))
           (opt-src-address (unwrap (read-u32be buffer 0)))
           (opt-dst-address (unwrap (read-u32be buffer 0)))
           (opt-max-cid (unwrap (read-u16be buffer 0)))
