        (cons 'data-int64 (list (cons 'raw data-int64) (cons 'formatted (number->string data-int64))))
        (cons 'data-uint64 (list (cons 'raw data-uint64) (cons 'formatted (number->string data-uint64))))
        (cons 'data-float (list (cons 'raw data-float) (cons 'formatted (number->string data-float))))
        (cons 'data-double (list (cons 'raw data-double) (cons 'formatted (number->string data-double))))
        (cons 'address-scheme-slot (list (cons 'raw address-scheme-slot) (cons 'formatted (number->string address-scheme-slot))))
        (cons 'address-scheme-menu (list (cons 'raw address-scheme-menu) (cons 'formatted (number->string address-scheme-menu))))
        (cons 'address-scheme-parameter (list (cons 'raw address-scheme-parameter) (cons 'formatted (number->string address-scheme-parameter))))
        (cons 'address-scheme-null-byte-size (list (cons 'raw address-scheme-null-byte-size) (cons 'formatted (number->string address-scheme-null-byte-size))))
        (cons 'number-of-subsequent-object-requests (list (cons 'raw number-of-subsequent-object-requests) (cons 'formatted (number->string number-of-subsequent-object-requests))))
        (cons 'number-of-parameter-definitions (list (cons 'raw number-of-parameter-definitions) (cons 'formatted (number->string number-of-parameter-definitions))))
        (cons 'min-param-menu (list (cons 'raw min-param-menu) (cons 'formatted (number->string min-param-menu))))
        (cons 'max-param-menu (list (cons 'raw max-param-menu) (cons 'formatted (number->string max-param-menu))))
        (cons 'string-id (list (cons 'raw string-id) (cons 'formatted (utf8->string string-id))))
        (cons 'number-of-parameter-responses (list (cons 'raw number-of-parameter-responses) (cons 'formatted (number->string number-of-parameter-responses))))
        (cons 'number-of-decimal-places (list (cons 'raw number-of-decimal-places) (cons 'formatted (number->string number-of-decimal-places))))
