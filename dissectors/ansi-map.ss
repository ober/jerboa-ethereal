        (cons 'map-triggercapability-pa (list (cons 'raw map-triggercapability-pa) (cons 'formatted (if (= map-triggercapability-pa 0) "triggers cannot be armed by the TriggerAddressList parameter" "triggers can be armed by the TriggerAddressList parameter"))))
