        (cons 'ssc-readposition-partition-number (list (cons 'raw ssc-readposition-partition-number) (cons 'formatted (number->string ssc-readposition-partition-number))))
        (cons 'ssc-readposition-block-number (list (cons 'raw ssc-readposition-block-number) (cons 'formatted (number->string ssc-readposition-block-number))))
