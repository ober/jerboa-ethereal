        (cons 'ssc-reten (list (cons 'raw ssc-reten) (cons 'formatted (if (= ssc-reten 0) "Not set" "Set"))))
        (cons 'ssc-load (list (cons 'raw ssc-load) (cons 'formatted (if (= ssc-load 0) "Not set" "Set"))))
        (cons 'ssc-capacity-prop-value (list (cons 'raw ssc-capacity-prop-value) (cons 'formatted (number->string ssc-capacity-prop-value))))
        (cons 'ssc-locate-flags (list (cons 'raw ssc-locate-flags) (cons 'formatted (fmt-hex ssc-locate-flags))))
        (cons 'ssc-cp (list (cons 'raw ssc-cp) (cons 'formatted (if (= ssc-cp 0) "Not set" "Set"))))
        (cons 'ssc-locate10-loid (list (cons 'raw ssc-locate10-loid) (cons 'formatted (number->string ssc-locate10-loid))))
        (cons 'ssc-bam-flags (list (cons 'raw ssc-bam-flags) (cons 'formatted (fmt-hex ssc-bam-flags))))
        (cons 'ssc-bam (list (cons 'raw ssc-bam) (cons 'formatted (if (= ssc-bam 0) "Not set" "Set"))))
        (cons 'ssc-erase6-immed (list (cons 'raw ssc-erase6-immed) (cons 'formatted (number->string ssc-erase6-immed))))
