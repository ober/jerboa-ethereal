        (cons 'ssc-formatmedium-flags (list (cons 'raw ssc-formatmedium-flags) (cons 'formatted (fmt-hex ssc-formatmedium-flags))))
        (cons 'ssc-verify (list (cons 'raw ssc-verify) (cons 'formatted (if (= ssc-verify 0) "Not set" "Set"))))
        (cons 'ssc-immed (list (cons 'raw ssc-immed) (cons 'formatted (if (= ssc-immed 0) "Not set" "Set"))))
        (cons 'ssc-rdwr10-xferlen (list (cons 'raw ssc-rdwr10-xferlen) (cons 'formatted (number->string ssc-rdwr10-xferlen))))
