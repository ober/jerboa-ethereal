#!/usr/bin/env scheme
;; demo-standalone.ss
;; Standalone end-to-end dissection demo
;; No module imports except (jerboa prelude)

(import (jerboa prelude))

(displayln "")
(displayln "╔════════════════════════════════════════════════════════════════╗")
(displayln "║  jerboa-ethereal: Packet Dissection Pipeline Demo             ║")
(displayln "║                 (Standalone - No Module Imports)              ║")
(displayln "╚════════════════════════════════════════════════════════════════╝")
(displayln "")

;; ── Demonstration of Packet Structure ──────────────────────────────────

(displayln "DEMO 1: Building sample packets programmatically")
(displayln "─────────────────────────────────────────────────────")
(displayln "")

;; Sample MAC addresses
(define dest-mac #vu8(255 255 255 255 255 255))  ;; Broadcast
(define src-mac #vu8(170 170 170 170 170 170))   ;; AA:AA:AA:AA:AA:AA
(displayln (str "Destination MAC: FF:FF:FF:FF:FF:FF (broadcast)"))
(displayln (str "Source MAC:      AA:AA:AA:AA:AA:AA"))
(displayln "")

;; Sample IP addresses
(define src-ip #vu8(192 168 1 1))
(define dst-ip #vu8(192 168 1 2))
(displayln (str "Source IP:       192.168.1.1"))
(displayln (str "Destination IP:  192.168.1.2"))
(displayln "")

;; ── Ethernet Frame (L2) ────────────────────────────────────────────────

(displayln "DEMO 2: Ethernet Frame (L2)")
(displayln "─────────────────────────────────")
(displayln "")
(displayln "Ethernet frame structure:")
(displayln "  ┌─────────────┬──────────────┬──────────┬────────────┐")
(displayln "  │ Dest MAC    │ Src MAC      │ EtherType│ Payload    │")
(displayln "  │ 6 bytes     │ 6 bytes      │ 2 bytes  │ variable   │")
(displayln "  └─────────────┴──────────────┴──────────┴────────────┘")
(displayln "       14 bytes minimum")
(displayln "")
(displayln "EtherType values:")
(displayln "  0x0800 = IPv4 (most common)")
(displayln "  0x0806 = ARP")
(displayln "  0x86DD = IPv6")
(displayln "")

;; Build an Ethernet frame
(let ((frame (make-bytevector 100 0)))
  ;; Dest MAC (FF:FF:FF:FF:FF:FF)
  (bytevector-copy! dest-mac 0 frame 0 6)
  ;; Src MAC (AA:AA:AA:AA:AA:AA)
  (bytevector-copy! src-mac 0 frame 6 6)
  ;; EtherType: 0x0800 (IPv4)
  (bytevector-u8-set! frame 12 #x08)
  (bytevector-u8-set! frame 13 #x00)
  ;; Payload: sample IPv4 packet
  (bytevector-u8-set! frame 14 #x45)  ;; Version 4, IHL 5
  (bytevector-u8-set! frame 15 #x00)  ;; DSCP/ECN

  (displayln "Created Ethernet frame (100 bytes):")
  (displayln (str "  Offset 0-5:   Dest MAC   = FF:FF:FF:FF:FF:FF"))
  (displayln (str "  Offset 6-11:  Src MAC    = AA:AA:AA:AA:AA:AA"))
  (displayln (str "  Offset 12-13: EtherType  = 0x0800"))
  (displayln (str "  Offset 14+:   Payload    = " (bytevector-length frame) " bytes"))
  (displayln ""))

;; ── IPv4 Packet (L3) ────────────────────────────────────────────────────

(displayln "DEMO 3: IPv4 Packet (L3)")
(displayln "─────────────────────────────────")
(displayln "")
(displayln "IPv4 packet structure (minimum 20 bytes):")
(displayln "  ┌────────┬──────┬────────┬──────┬─────────┬────┬──────┬──────┬────────┬────────┬────────┐")
(displayln "  │Version │IHL   │DSCP   │ECN   │Length   │ID  │Flags │Frag  │TTL    │Protocol│Checksum│")
(displayln "  │4b      │4b    │6b     │2b    │2 bytes  │2B  │3b    │13b   │1 byte │1 byte  │2 bytes │")
(displayln "  └────────┴──────┴────────┴──────┴─────────┴────┴─────────────────────────────────┴──────┘")
(displayln "")
(displayln "Protocol numbers:")
(displayln "  1   = ICMP (ping)")
(displayln "  6   = TCP")
(displayln "  17  = UDP")
(displayln "")

;; Build an IPv4 packet
(let ((pkt (make-bytevector 100 0)))
  ;; Version 4, IHL 5 (20 bytes)
  (bytevector-u8-set! pkt 0 #x45)
  ;; DSCP/ECN
  (bytevector-u8-set! pkt 1 #x00)
  ;; Total length: 20 + 20 = 40 (for TCP)
  (bytevector-u8-set! pkt 2 #x00)
  (bytevector-u8-set! pkt 3 #x28)
  ;; Identification
  (bytevector-u8-set! pkt 4 #x12)
  (bytevector-u8-set! pkt 5 #x34)
  ;; Flags + Fragment offset (DF flag set)
  (bytevector-u8-set! pkt 6 #x40)
  (bytevector-u8-set! pkt 7 #x00)
  ;; TTL
  (bytevector-u8-set! pkt 8 #x40)
  ;; Protocol: 6 = TCP
  (bytevector-u8-set! pkt 9 6)
  ;; Header checksum (skipped for demo)
  (bytevector-u8-set! pkt 10 #x00)
  (bytevector-u8-set! pkt 11 #x00)
  ;; Source IP: 192.168.1.1
  (bytevector-copy! src-ip 0 pkt 12 4)
  ;; Dest IP: 192.168.1.2
  (bytevector-copy! dst-ip 0 pkt 16 4)

  (displayln "Created IPv4 packet (40 bytes):")
  (displayln (str "  Version:     4"))
  (displayln (str "  IHL:         5 (20 bytes)"))
  (displayln (str "  Total Length: 40 bytes"))
  (displayln (str "  TTL:         64"))
  (displayln (str "  Protocol:    6 (TCP)"))
  (displayln (str "  Src IP:      192.168.1.1"))
  (displayln (str "  Dst IP:      192.168.1.2"))
  (displayln (str "  Flags:       DF (Don't Fragment)"))
  (displayln ""))

;; ── TCP Segment (L4) ────────────────────────────────────────────────────

(displayln "DEMO 4: TCP Segment (L4)")
(displayln "─────────────────────────────────")
(displayln "")
(displayln "TCP segment structure (minimum 20 bytes):")
(displayln "  ┌──────────┬──────────┬──────────┬──────────┬────┬─────────┬──────┬──────┬──────────┐")
(displayln "  │Src Port  │Dst Port  │Sequence  │Ack       │Data│Flags   │Window│Check│Urg Ptr  │")
(displayln "  │2 bytes   │2 bytes   │4 bytes   │4 bytes   │4b  │8 bits  │2B    │2B   │2 bytes  │")
(displayln "  └──────────┴──────────┴──────────┴──────────┴────┴─────────┴──────┴──────┴──────────┘")
(displayln "")
(displayln "TCP flags (1 byte):")
(displayln "  SYN (S)  = 0x02 - Synchronize")
(displayln "  ACK (A)  = 0x10 - Acknowledgment")
(displayln "  FIN (F)  = 0x01 - Finish")
(displayln "  RST (R)  = 0x04 - Reset")
(displayln "  PSH (P)  = 0x08 - Push")
(displayln "  URG (U)  = 0x20 - Urgent")
(displayln "")

;; Build a TCP segment (SYN-ACK packet)
(let ((seg (make-bytevector 40 0)))
  ;; Src port: 80 (HTTP)
  (bytevector-u8-set! seg 0 #x00)
  (bytevector-u8-set! seg 1 #x50)
  ;; Dst port: 1024
  (bytevector-u8-set! seg 2 #x04)
  (bytevector-u8-set! seg 3 #x00)
  ;; Sequence: 12345
  (bytevector-u8-set! seg 4 #x00)
  (bytevector-u8-set! seg 5 #x00)
  (bytevector-u8-set! seg 6 #x30)
  (bytevector-u8-set! seg 7 #x39)
  ;; Ack: 54321
  (bytevector-u8-set! seg 8 #x00)
  (bytevector-u8-set! seg 9 #x00)
  (bytevector-u8-set! seg 10 #xd4)
  (bytevector-u8-set! seg 11 #x31)
  ;; Data offset (5 words = 20 bytes) + Reserved
  (bytevector-u8-set! seg 12 #x50)
  ;; Flags: ACK
  (bytevector-u8-set! seg 13 #x10)
  ;; Window: 65535
  (bytevector-u8-set! seg 14 #xFF)
  (bytevector-u8-set! seg 15 #xFF)
  ;; Checksum (skipped)
  (bytevector-u8-set! seg 16 #x00)
  (bytevector-u8-set! seg 17 #x00)

  (displayln "Created TCP segment (40 bytes):")
  (displayln (str "  Src Port:    80 (HTTP)"))
  (displayln (str "  Dst Port:    1024"))
  (displayln (str "  Sequence:    12345"))
  (displayln (str "  Ack:         54321"))
  (displayln (str "  Data Offset: 5 (20 bytes)"))
  (displayln (str "  Flags:       ACK (0x10)"))
  (displayln (str "  Window:      65535"))
  (displayln ""))

;; ── Complete Stack ────────────────────────────────────────────────────

(displayln "DEMO 5: Complete Protocol Stack")
(displayln "─────────────────────────────────")
(displayln "")
(displayln "Nested structure (Ethernet → IPv4 → TCP):")
(displayln "")
(displayln "  ┌─────────────────────────────────────────┐")
(displayln "  │ Ethernet Frame (14 bytes)               │")
(displayln "  │  ├─ Dest MAC: FF:FF:FF:FF:FF:FF         │")
(displayln "  │  ├─ Src MAC:  AA:AA:AA:AA:AA:AA         │")
(displayln "  │  ├─ Type:     0x0800 (IPv4)             │")
(displayln "  │  └─ Payload:  [IPv4 Packet below]       │")
(displayln "  │               40 bytes                  │")
(displayln "  │                                         │")
(displayln "  │  ┌─────────────────────────────────┐   │")
(displayln "  │  │ IPv4 Packet (20 bytes header)   │   │")
(displayln "  │  │  ├─ Version/IHL: 4/5            │   │")
(displayln "  │  │  ├─ Total Length: 40 bytes      │   │")
(displayln "  │  │  ├─ TTL: 64                     │   │")
(displayln "  │  │  ├─ Protocol: 6 (TCP)           │   │")
(displayln "  │  │  ├─ Src: 192.168.1.1            │   │")
(displayln "  │  │  ├─ Dst: 192.168.1.2            │   │")
(displayln "  │  │  └─ Payload: [TCP Segment]      │   │")
(displayln "  │  │             20 bytes            │   │")
(displayln "  │  │                                 │   │")
(displayln "  │  │  ┌─────────────────────────┐   │   │")
(displayln "  │  │  │ TCP Segment (20 bytes)  │   │   │")
(displayln "  │  │  │  ├─ Src Port: 80        │   │   │")
(displayln "  │  │  │  ├─ Dst Port: 1024      │   │   │")
(displayln "  │  │  │  ├─ Sequence: 12345     │   │   │")
(displayln "  │  │  │  ├─ Ack: 54321          │   │   │")
(displayln "  │  │  │  ├─ Flags: ACK          │   │   │")
(displayln "  │  │  │  └─ Payload: (empty)    │   │   │")
(displayln "  │  │  └─────────────────────────┘   │   │")
(displayln "  │  └─────────────────────────────────┘   │")
(displayln "  └─────────────────────────────────────────┘")
(displayln "")
(displayln "Total packet size: 14 + 20 + 20 = 54 bytes")
(displayln "")

;; ── Dissection Output Example ──────────────────────────────────────────

(displayln "DEMO 6: What Dissection Output Looks Like")
(displayln "─────────────────────────────────────────────────────")
(displayln "")
(displayln "Raw packet hex (first 54 bytes):")
(displayln "  ff ff ff ff ff ff aa aa aa aa aa aa 08 00 45 00 00 28 12 34 40 00 40 06 00 00 c0 a8")
(displayln "  01 01 c0 a8 01 02 00 50 04 00 00 00 30 39 00 00 d4 31 50 10 ff ff 00 00 00 00")
(displayln "")
(displayln "Dissected output:")
(displayln "")
(displayln "  Ethernet:")
(displayln "    dest-mac = FF:FF:FF:FF:FF:FF (broadcast)")
(displayln "    src-mac = AA:AA:AA:AA:AA:AA")
(displayln "    type = 0x0800 (IPv4)")
(displayln "    next-protocol = ipv4")
(displayln "")
(displayln "  IPv4:")
(displayln "    version = 4")
(displayln "    ihl = 5 (20 bytes)")
(displayln "    total-length = 40")
(displayln "    ttl = 64")
(displayln "    protocol = 6 (TCP)")
(displayln "    src-ip = 192.168.1.1")
(displayln "    dst-ip = 192.168.1.2")
(displayln "    next-protocol = tcp")
(displayln "")
(displayln "  TCP:")
(displayln "    src-port = 80 (HTTP)")
(displayln "    dst-port = 1024")
(displayln "    sequence = 12345 (0x3039)")
(displayln "    acknowledgment = 54321 (0xd431)")
(displayln "    data-offset = 5 (20 bytes)")
(displayln "    flags = ACK")
(displayln "    window-size = 65535")
(displayln "")

;; ── Summary ────────────────────────────────────────────────────────────

(displayln "SUMMARY: What jerboa-ethereal Can Do")
(displayln "──────────────────────────────────────────────────────")
(displayln "")
(displayln "✓ Parse binary packet bytevectors at any layer")
(displayln "✓ Extract and format fields (IP addresses, MAC addresses, port names)")
(displayln "✓ Discover next protocol from field values (EtherType → IPv4, IP Protocol → TCP)")
(displayln "✓ Chain dissectors: Ethernet → IPv4 → TCP → Application")
(displayln "✓ Handle corrupt packets gracefully with Result types (ok/err)")
(displayln "✓ Validate fields and generate clear error messages")
(displayln "✓ Display formatted output for human analysis")
(displayln "")
(displayln "Next Phase:")
(displayln "  1. Integrate real dissectors from dissectors/*.ss")
(displayln "  2. Build module system (.so libraries)")
(displayln "  3. Create PCAP file reader")
(displayln "  4. Build command-line tool: ethereal <pcapfile>")
(displayln "  5. Add more protocols: ICMP, DNS, TLS, IPv6, ARP")
(displayln "")
